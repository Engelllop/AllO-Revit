<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sólo overrides de color: estilos completos vienen de AllOTheme.xaml -->
    <SolidColorBrush x:Key="Deep"          Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Surface"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Panel"         Color="#F4F4F4"/>
    <SolidColorBrush x:Key="Card"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Overlay"       Color="#ECECEC"/>
    <SolidColorBrush x:Key="Sidebar"       Color="#F0F0F0"/>
    <SolidColorBrush x:Key="SidebarHover"  Color="#E5E5E5"/>
    <SolidColorBrush x:Key="SidebarActive" Color="#D8D8D8"/>

    <SolidColorBrush x:Key="Border"        Color="#D0D0D0"/>
    <SolidColorBrush x:Key="BorderLight"   Color="#BFBFBF"/>

    <SolidColorBrush x:Key="TextPrimary"   Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#555555"/>
    <SolidColorBrush x:Key="TextMuted"     Color="#7A7A7A"/>
    <SolidColorBrush x:Key="TextAccent"    Color="#333333"/>

    <SolidColorBrush x:Key="Accent"        Color="#1F1F1F"/>
    <SolidColorBrush x:Key="AccentHover"   Color="#000000"/>
    <SolidColorBrush x:Key="Success"       Color="#059669"/>
    <SolidColorBrush x:Key="Warning"       Color="#D97706"/>
    <SolidColorBrush x:Key="Danger"        Color="#DC2626"/>
    <SolidColorBrush x:Key="Orange"        Color="#EA580C"/>
    <SolidColorBrush x:Key="Teal"          Color="#0D9488"/>
</ResourceDictionary>
