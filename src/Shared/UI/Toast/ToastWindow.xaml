<Window x:Class="AllO.UI.Toast.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" Width="340" Height="Auto"
        SizeToContent="Height">
    <Border Background="#1E1E1E" CornerRadius="8" Margin="10" Padding="0">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
        </Border.Effect>
        <StackPanel x:Name="ToastPanel"/>
    </Border>
</Window>
