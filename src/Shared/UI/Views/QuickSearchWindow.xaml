<Window x:Class="AllO.UI.Views.QuickSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Quick Search"
        Height="680" Width="700"
        MinHeight="500" MinWidth="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#15151E">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg"   Color="#15151E"/>
        <SolidColorBrush x:Key="Sf"   Color="#1B1B28"/>
        <SolidColorBrush x:Key="Cd"   Color="#1E1E32"/>
        <SolidColorBrush x:Key="CdH"  Color="#252542"/>
        <SolidColorBrush x:Key="Bdr"  Color="#2A2A42"/>
        <SolidColorBrush x:Key="Txt"  Color="#E8E8F0"/>
        <SolidColorBrush x:Key="Tx2"  Color="#9999B3"/>
        <SolidColorBrush x:Key="TxM"  Color="#666680"/>
        <SolidColorBrush x:Key="TxA"  Color="#9B93FF"/>
        <SolidColorBrush x:Key="Acc"  Color="#6C63FF"/>
        <SolidColorBrush x:Key="AcH"  Color="#5B53E8"/>
        <SolidColorBrush x:Key="Suc"  Color="#34D399"/>

        <!-- Toggle Chip (CheckBox styled as pill) -->
        <Style x:Key="ToggleChip" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd" Background="{StaticResource Cd}"
                                BorderBrush="{StaticResource Bdr}" BorderThickness="1"
                                CornerRadius="16" Padding="14,8" Margin="0,0,6,6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Dot" Width="8" Height="8" Fill="{StaticResource TxM}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C1C3A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Acc}"/>
                                <Setter TargetName="Dot" Property="Fill" Value="{StaticResource Acc}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CdH}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Box (large) -->
        <Style x:Key="SearchMain" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A2C"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Txt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Foreground="{StaticResource TxM}"
                                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                                <ScrollViewer Grid.Column="1" x:Name="PART_ContentHost" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Acc}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnP" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Acc}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource AcH}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnS" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Cd}"/>
            <Setter Property="Foreground" Value="{StaticResource Tx2}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource CdH}"/><Setter Property="Foreground" Value="{StaticResource Txt}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource BtnP}">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#047857"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgHdr" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A2C"/>
            <Setter Property="Foreground" Value="#7070A0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#222240"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgC" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#25254A"/><Setter Property="Foreground" Value="White"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgR" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1F1F38"/></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header + Search -->
            <RowDefinition Height="Auto"/>   <!-- Toggles -->
            <RowDefinition Height="*"/>      <!-- Results -->
            <RowDefinition Height="Auto"/>   <!-- Actions -->
            <RowDefinition Height="Auto"/>   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER + SEARCH BAR ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource Sf}"
                BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1"
                Padding="20,16,20,14">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="AllO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Acc}"/>
                    <TextBlock Text="Quick Search" FontSize="20" FontWeight="Light" Foreground="{StaticResource Txt}" Margin="10,0,0,0"/>
                </StackPanel>

                <TextBox Style="{StaticResource SearchMain}"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         x:Name="SearchBox"/>
            </StackPanel>
        </Border>

        <!-- ═══════ SEARCH SCOPE TOGGLES (chips) ═══════ -->
        <Border Grid.Row="1" Background="#191928"
                BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1"
                Padding="20,12">
            <StackPanel>
                <TextBlock Text="SEARCH IN" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TxM}" Margin="0,0,0,8"/>
                <WrapPanel>
                    <CheckBox Style="{StaticResource ToggleChip}" IsChecked="{Binding SearchByName}">
                        <TextBlock Text="Element Name" FontSize="12" Foreground="{StaticResource Txt}"/>
                    </CheckBox>
                    <CheckBox Style="{StaticResource ToggleChip}" IsChecked="{Binding SearchById}">
                        <TextBlock Text="Element ID" FontSize="12" Foreground="{StaticResource Txt}"/>
                    </CheckBox>
                    <CheckBox Style="{StaticResource ToggleChip}" IsChecked="{Binding SearchByCategory}">
                        <TextBlock Text="Category" FontSize="12" Foreground="{StaticResource Txt}"/>
                    </CheckBox>
                    <CheckBox Style="{StaticResource ToggleChip}" IsChecked="{Binding SearchByFamily}">
                        <TextBlock Text="Family / Type" FontSize="12" Foreground="{StaticResource Txt}"/>
                    </CheckBox>
                    <CheckBox Style="{StaticResource ToggleChip}" IsChecked="{Binding SearchByParameter}">
                        <TextBlock Text="Parameter Value" FontSize="12" Foreground="{StaticResource Txt}"/>
                    </CheckBox>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ═══════ RESULTS ═══════ -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding ResultsView}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Extended" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A1A30"
                  Background="{StaticResource Bg}" BorderThickness="0"
                  RowBackground="#1B1B28" AlternatingRowBackground="#1D1D2E"
                  Foreground="{StaticResource Txt}" FontSize="12.5"
                  RowHeight="36" ColumnHeaderHeight="32"
                  ColumnHeaderStyle="{StaticResource DgHdr}" CellStyle="{StaticResource DgC}" RowStyle="{StaticResource DgR}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="ID" Width="70" Binding="{Binding ElementId}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TxM}"/>
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Name" Width="*" Binding="{Binding Name}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Category" Width="120" Binding="{Binding Category}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TxA}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Family / Type" Width="160" Binding="{Binding FamilyType}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource Tx2}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Level" Width="90" Binding="{Binding LevelName}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TxM}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Match" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A35" CornerRadius="8" Padding="6,2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding MatchedOn}" FontSize="10" Foreground="{StaticResource Suc}" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Zoom button -->
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ZoomToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding ElementId}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    ToolTip="Zoom to element" Padding="4">
                                <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource TxM}"/>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══════ ACTIONS BAR ═══════ -->
        <Border Grid.Row="3" Background="#191928"
                BorderBrush="{StaticResource Bdr}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Select All" Style="{StaticResource BtnS}" Command="{Binding SelectAllCommand}" FontSize="11" Padding="10,6"/>
                <Button Grid.Column="2" Content="Select None" Style="{StaticResource BtnS}" Command="{Binding SelectNoneCommand}" FontSize="11" Padding="10,6"/>

                <Button Grid.Column="4" Style="{StaticResource BtnP}" Command="{Binding SelectInRevitCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE762;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Select in Revit" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedCount, StringFormat=' ({0})'}" FontSize="12" Opacity="0.6"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="6" Style="{StaticResource BtnGreen}" Command="{Binding IsolateInViewCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Isolate in View" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════ STATUS BAR ═══════ -->
        <Border Grid.Row="4" Background="#111119" BorderBrush="#1A1A2E" BorderThickness="0,1,0,0" Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding ResultCount}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Tx2}"/>
                    <TextBlock Text=" results" FontSize="12" Foreground="{StaticResource TxM}"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="#222240" Margin="8,2"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{Binding SelectedCount}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TxA}"/>
                    <TextBlock Text=" selected" FontSize="12" Foreground="{StaticResource TxM}"/>
                </StackPanel>

                <TextBlock Grid.Column="4" Text="{Binding StatusMessage}" FontSize="11.5" Foreground="{StaticResource TxM}" VerticalAlignment="Center"/>

                <Button Grid.Column="5" Content="Close" Style="{StaticResource BtnS}" Command="{Binding CloseCommand}" FontSize="11" Padding="12,5"/>
            </Grid>
        </Border>
    </Grid>
</Window>
