<Window x:Class="AllO.UI.Views.LinkVisibilityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Link Display"
        Style="{StaticResource AllOWindow}"
        Height="620" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Deep}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel>
                <TextBlock Text="{Binding DocumentName}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.55*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="0.45*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Views -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TARGET VIEWS" Style="{StaticResource Lbl}"/>
                <TextBox Grid.Row="1" Style="{StaticResource SearchBox}"
                         Text="{Binding ViewSearch, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Search views by name"
                         Margin="0,0,0,8"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Select All" Style="{StaticResource BtnSecondary}"
                            Command="{Binding SelectAllViewsCommand}"
                            ToolTip="Select all views"
                            Margin="0,0,8,0" Padding="10,5"/>
                    <Button Content="Select None" Style="{StaticResource BtnSecondary}"
                            Command="{Binding SelectNoneViewsCommand}"
                            ToolTip="Deselect all views"
                            Padding="10,5"/>
                </StackPanel>

                <Border Grid.Row="4" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                    <DockPanel>
                        <!-- Column header -->
                        <Border DockPanel.Dock="Top" Background="{StaticResource Surface}"
                                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="14,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="VIEW NAME" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Grid.Column="1" Text="TYPE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMuted}" Margin="0,0,4,0"/>
                            </Grid>
                        </Border>

                        <ListBox ItemsSource="{Binding ViewsView}" Background="Transparent" BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                                                        Padding="12,8" Margin="3,1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource Overlay}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" Style="{StaticResource DkCheck}"
                                                  IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimary}" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="2" Background="{StaticResource Overlay}" CornerRadius="4"
                                                Padding="7,2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ViewType}" FontSize="10"
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Right Panel: Link Settings -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="LINKED MODEL" Style="{StaticResource Lbl}"/>
                <ComboBox Grid.Row="1" Style="{StaticResource DarkCombo}"
                          ItemContainerStyle="{StaticResource DarkComboItem}"
                          ItemsSource="{Binding Links}"
                          SelectedItem="{Binding SelectedLink}"
                          DisplayMemberPath="Name"
                          ToolTip="Select a linked Revit model"
                          Margin="0,0,0,16"/>

                <TextBlock Grid.Row="2" Text="DISPLAY MODE" Style="{StaticResource Lbl}"/>
                <ComboBox Grid.Row="3" Style="{StaticResource DarkCombo}"
                          ItemContainerStyle="{StaticResource DarkComboItem}"
                          ItemsSource="{Binding DisplayModes}"
                          SelectedItem="{Binding SelectedDisplayMode}"
                          ToolTip="Choose how the linked model should display in the selected views"
                          Margin="0,0,0,12"/>

                <Border Grid.Row="4" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="About Display Modes" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6"/>
                        <TextBlock Text="By Host View — Link follows the visibility settings of the current host view." FontSize="10" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="By Linked View — Link uses a specific view from the linked model." FontSize="10" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <TextBlock Text="Custom — Link uses independent visibility settings (set manually in Revit)." FontSize="10" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="5" Text="PREVIEW" Style="{StaticResource Lbl}"/>
                <Border Grid.Row="6" Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedLink.Name, FallbackValue='No link selected'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SelectedDisplayMode, StringFormat='Will be set to: {0}'}" FontSize="11" Foreground="{StaticResource Success}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding Views.Count, StringFormat='Across {0} total views'}" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Background="{StaticResource Deep}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Refresh" Style="{StaticResource BtnSecondary}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Reload links and views"
                        Margin="0,0,8,0"/>

                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" TextWrapping="Wrap" Margin="8,0"/>

                <Button Grid.Column="4" Content="Apply" Style="{StaticResource BtnPrimary}"
                        Command="{Binding ApplyCommand}"
                        ToolTip="Apply display mode to selected views"/>
                <Button Grid.Column="6" Content="Close" Style="{StaticResource BtnSecondary}"
                        Command="{Binding CloseCommand}"
                        ToolTip="Close the window"/>
            </Grid>
        </Border>
    </Grid>
</Window>
