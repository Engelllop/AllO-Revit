<Window x:Class="AllO.UI.Views.SuperToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AllO — Toolkit"
        Height="720" Width="1000"
        MinHeight="550" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E">

    <Window.Resources>
        <SolidColorBrush x:Key="Deep"     Color="#1E1E1E"/>
        <SolidColorBrush x:Key="Surface"  Color="#252525"/>
        <SolidColorBrush x:Key="Panel"    Color="#2C2C2C"/>
        <SolidColorBrush x:Key="Card"     Color="#303030"/>
        <SolidColorBrush x:Key="Overlay"  Color="#3B3B3B"/>
        <SolidColorBrush x:Key="Bdr"      Color="#383838"/>
        <SolidColorBrush x:Key="BdrL"     Color="#494949"/>
        <SolidColorBrush x:Key="Txt"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="Txt2"     Color="#999999"/>
        <SolidColorBrush x:Key="TxtM"     Color="#787878"/>
        <SolidColorBrush x:Key="TxtA"     Color="#CCCCCC"/>
        <SolidColorBrush x:Key="Acc"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="AccH"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Suc"      Color="#34D399"/>
        <SolidColorBrush x:Key="Err"      Color="#FB7185"/>
        <SolidColorBrush x:Key="Wrn"      Color="#FBBF24"/>
        <SolidColorBrush x:Key="Orange"   Color="#F97316"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ═══ BUTTONS ═══ -->
        <Style x:Key="BtnP" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Acc}"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccH}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnS" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Card}"/>
            <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Overlay}"/>
                                <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnS}">
            <Setter Property="Foreground" Value="{StaticResource Err}"/>
            <Setter Property="BorderBrush" Value="#3D2020"/>
        </Style>

        <!-- ═══ TEXTBOX ═══ -->
        <Style x:Key="TBox" TargetType="TextBox">
            <Setter Property="Background" Value="#272727"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Txt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Acc}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ═══ COMBOBOX ═══ -->
        <ControlTemplate x:Key="CbToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Bg" Grid.ColumnSpan="2" Background="#272727"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="1" CornerRadius="4"/>
                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="#909090" StrokeThickness="1.5"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Acc}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource CbToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <TextBlock Text="{TemplateBinding SelectionBoxItem}"
                                       Margin="10,7,28,7" VerticalAlignment="Center"
                                       IsHitTestVisible="False" TextTrimming="CharacterEllipsis"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Focusable="False" AllowsTransparency="True" PopupAnimation="Slide">
                                <Border Background="#2C2C2C" BorderBrush="{StaticResource Bdr}"
                                        BorderThickness="1" CornerRadius="4" Margin="0,2,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3B3B3B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#414141"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ DATAGRID ═══ -->
        <Style x:Key="DgH" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#272727"/>
            <Setter Property="Foreground" Value="#828282"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#323232"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgC" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#323232"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgR" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E2E2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgRSync" TargetType="DataGridRow" BasedOn="{StaticResource DgR}">
            <Setter Property="MinHeight" Value="44"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSyncMismatch}" Value="True">
                    <Setter Property="Background" Value="#2D2418"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Orange}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ SIDEBAR NAV ═══ -->
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="4,1">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E2E"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Acc}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#686868"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SIDEBAR                                     -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,20">
                    <TextBlock Text="AllO" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Acc}"/>
                    <TextBlock Text="Toolkit" FontSize="11" Foreground="{StaticResource TxtM}" Margin="1,0,0,0"/>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Margin="4,0">
                    <RadioButton Style="{StaticResource NavBtn}" IsChecked="True"
                                 Checked="NavTab_Checked" Tag="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Copy Crop"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavBtn}"
                                 Checked="NavTab_Checked" Tag="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Grids"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavBtn}"
                                 Checked="NavTab_Checked" Tag="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Levels"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ TAB 0: COPY CROP ═══ -->
            <Grid Grid.Row="0" Visibility="{Binding IsCropTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Copy Crop" Style="{StaticResource BtnP}" Command="{Binding CopyCropCommand}" Margin="0,0,8,0"/>
                        <Button Content="Select All" Style="{StaticResource BtnS}" Command="{Binding CropSelectAllCommand}" Margin="0,0,4,0"/>
                        <Button Content="Select None" Style="{StaticResource BtnS}" Command="{Binding CropSelectNoneCommand}" Margin="0,0,16,0"/>
                        <TextBox Style="{StaticResource TBox}" Width="200"
                                 Text="{Binding CropSearch, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Source selection -->
                <Border Grid.Row="1" Background="#262626" Padding="16,10"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="BASE SOURCE VIEW" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TxtM}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Style="{StaticResource DkCombo}" Width="350"
                                  ItemsSource="{Binding CropViews}"
                                  SelectedItem="{Binding CropSourceView}"
                                  DisplayMemberPath="Name"
                                  ItemContainerStyle="{StaticResource DkComboItem}"/>
                        <TextBlock Text="→  Select targets below" FontSize="11"
                                   Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Target views list -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding CropViewsView}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#272727"
                          Background="{StaticResource Deep}" BorderThickness="0"
                          RowBackground="#282828" AlternatingRowBackground="#2B2B2B"
                          Foreground="{StaticResource Txt}" FontSize="12.5"
                          RowHeight="36" ColumnHeaderHeight="32"
                          ColumnHeaderStyle="{StaticResource DgH}"
                          CellStyle="{StaticResource DgC}" RowStyle="{StaticResource DgR}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="View Name" Width="*" Binding="{Binding Name}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Type" Width="120" Binding="{Binding ViewType}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Crop Active" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="No"/>
                                                <Setter Property="Foreground" Value="{StaticResource TxtM}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCropActive}" Value="True">
                                                        <Setter Property="Text" Value="Yes"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Suc}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Status" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TxtM}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Done">
                                                        <Setter Property="Foreground" Value="{StaticResource Suc}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Foreground" Value="{StaticResource Err}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Applying...">
                                                        <Setter Property="Foreground" Value="{StaticResource Wrn}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ═══ TAB 1: GRIDS ═══ -->
            <Grid Grid.Row="0" Visibility="{Binding IsGridTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Rename" Style="{StaticResource BtnP}" Command="{Binding RenameGridsCommand}" Margin="0,0,8,0"/>
                        <Button Content="Delete Selected" Style="{StaticResource BtnDanger}" Command="{Binding DeleteGridsCommand}" Margin="0,0,8,0"/>
                        <Button Content="Select All" Style="{StaticResource BtnS}" Command="{Binding GridSelectAllCommand}" Margin="0,0,4,0"/>
                        <Button Content="Select None" Style="{StaticResource BtnS}" Command="{Binding GridSelectNoneCommand}" Margin="0,0,16,0"/>
                        <TextBox Style="{StaticResource TBox}" Width="200"
                                 Text="{Binding GridSearch, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Reference link + copy -->
                <Border Grid.Row="1" Background="#262626" Padding="16,10"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="REFERENCE LINK" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TxtM}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Style="{StaticResource DkCombo}" Width="280"
                                  ItemsSource="{Binding ReferenceLinks}"
                                  SelectedItem="{Binding SelectedReferenceLink}"
                                  DisplayMemberPath="Name"
                                  ItemContainerStyle="{StaticResource DkComboItem}"/>
                        <Button Content="Copy from link" Style="{StaticResource BtnP}" Command="{Binding CopyGridsFromLinkCommand}" Margin="12,0,6,0"/>
                        <Button Content="Copy new only" Style="{StaticResource BtnS}" Command="{Binding CopyNewGridsOnlyCommand}" Margin="0,0,6,0"/>
                        <Button Content="Sync from link" Style="{StaticResource BtnS}" Command="{Binding SyncGridsFromLinkCommand}" ToolTip="Replace host grid geometry when it differs from the link"/>
                    </StackPanel>
                </Border>

                <!-- Prefix/Suffix -->
                <Border Grid.Row="2" Background="#262626" Padding="16,10"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="PREFIX:" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Style="{StaticResource TBox}" Width="100" Text="{Binding GridPrefix, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,0"/>
                        <TextBlock Text="SUFFIX:" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Style="{StaticResource TBox}" Width="100" Text="{Binding GridSuffix, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                        <Button Content="Apply to Selected" Style="{StaticResource BtnS}" Command="{Binding ApplyGridPrefixSuffixCommand}"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding GridsView}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#272727"
                          Background="{StaticResource Deep}" BorderThickness="0"
                          RowBackground="#282828" AlternatingRowBackground="#2B2B2B"
                          Foreground="{StaticResource Txt}" FontSize="12.5"
                          ColumnHeaderHeight="32"
                          ColumnHeaderStyle="{StaticResource DgH}"
                          CellStyle="{StaticResource DgC}" RowStyle="{StaticResource DgRSync}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Name" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TxtA}"/>
                                        <TextBlock Text="{Binding SyncWarning}" FontSize="10" Foreground="{StaticResource Orange}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasSyncMismatch, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="New Name" Width="150" Binding="{Binding NewName, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Suc}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#272727"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                                    <Setter Property="CaretBrush" Value="{StaticResource Txt}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Orientation" Width="120" Binding="{Binding Orientation}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Length (m)" Width="100" Binding="{Binding Length, StringFormat=F2}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ═══ TAB 2: LEVELS ═══ -->
            <Grid Grid.Row="0" Visibility="{Binding IsLevelTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Rename" Style="{StaticResource BtnP}" Command="{Binding RenameLevelsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Move" Style="{StaticResource BtnP}" Command="{Binding MoveLevelsCommand}" Margin="0,0,6,0"/>
                        <Button Content="Delete Selected" Style="{StaticResource BtnDanger}" Command="{Binding DeleteLevelsCommand}" Margin="0,0,8,0"/>
                        <Button Content="Select All" Style="{StaticResource BtnS}" Command="{Binding LevelSelectAllCommand}" Margin="0,0,4,0"/>
                        <Button Content="Select None" Style="{StaticResource BtnS}" Command="{Binding LevelSelectNoneCommand}" Margin="0,0,16,0"/>
                        <TextBox Style="{StaticResource TBox}" Width="200"
                                 Text="{Binding LevelSearch, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Reference link + copy -->
                <Border Grid.Row="1" Background="#262626" Padding="16,10"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="REFERENCE LINK" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TxtM}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Style="{StaticResource DkCombo}" Width="280"
                                  ItemsSource="{Binding ReferenceLinks}"
                                  SelectedItem="{Binding SelectedReferenceLink}"
                                  DisplayMemberPath="Name"
                                  ItemContainerStyle="{StaticResource DkComboItem}"/>
                        <Button Content="Copy from link" Style="{StaticResource BtnP}" Command="{Binding CopyLevelsFromLinkCommand}" Margin="12,0,6,0"/>
                        <Button Content="Copy new only" Style="{StaticResource BtnS}" Command="{Binding CopyNewLevelsOnlyCommand}" Margin="0,0,6,0"/>
                        <Button Content="Sync from link" Style="{StaticResource BtnS}" Command="{Binding SyncLevelsFromLinkCommand}" ToolTip="Move host levels to match linked elevations when they differ"/>
                    </StackPanel>
                </Border>

                <!-- Offset -->
                <Border Grid.Row="2" Background="#262626" Padding="16,10"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ELEVATION OFFSET (m):" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Style="{StaticResource TBox}" Width="100" Text="{Binding ElevationOffset, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                        <Button Content="Apply to Selected" Style="{StaticResource BtnS}" Command="{Binding ApplyElevationOffsetCommand}"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding LevelsView}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#272727"
                          Background="{StaticResource Deep}" BorderThickness="0"
                          RowBackground="#282828" AlternatingRowBackground="#2B2B2B"
                          Foreground="{StaticResource Txt}" FontSize="12.5"
                          ColumnHeaderHeight="32"
                          ColumnHeaderStyle="{StaticResource DgH}"
                          CellStyle="{StaticResource DgC}" RowStyle="{StaticResource DgRSync}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Name" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TxtA}"/>
                                        <TextBlock Text="{Binding SyncWarning}" FontSize="10" Foreground="{StaticResource Orange}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasSyncMismatch, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="New Name" Width="150" Binding="{Binding NewName, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Suc}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#272727"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                                    <Setter Property="CaretBrush" Value="{StaticResource Txt}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Elevation (m)" Width="120" Binding="{Binding Elevation, StringFormat=F3}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="New Elevation" Width="120" Binding="{Binding NewElevation, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{StaticResource Suc}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#272727"/>
                                    <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                                    <Setter Property="CaretBrush" Value="{StaticResource Txt}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Structural" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value=""/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStructural}" Value="True">
                                                        <Setter Property="Text" Value="Structural"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Wrn}"/>
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ═══ PROGRESS ═══ -->
            <Border Grid.Row="1" Background="#1A1A1A" Padding="20,6,20,4"
                    Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
                <ProgressBar Height="6" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                             Foreground="{StaticResource Orange}" Background="#2A2A2A" BorderThickness="0"/>
            </Border>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="#1A1A1A"
                    BorderBrush="#272727" BorderThickness="0,1,0,0" Padding="20,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11.5"
                               Foreground="{StaticResource TxtM}" VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="Refresh" Style="{StaticResource BtnS}"
                            Command="{Binding RefreshCommand}" FontSize="11" Padding="10,5"/>
                    <Button Grid.Column="3" Content="Close" Style="{StaticResource BtnS}"
                            Command="{Binding CloseCommand}" FontSize="11" Padding="12,5"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
