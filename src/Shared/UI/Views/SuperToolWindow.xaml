<Window x:Class="AllO.UI.Views.SuperToolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AllO — Toolkit"
        Style="{StaticResource AllOWindow}"
        Height="720" Width="1000"
        MinHeight="550" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Deep}">

    <Window.Resources>
        <ResourceDictionary>
            <!-- Window-specific row style for sync mismatch -->
            <Style x:Key="DgRSync" TargetType="DataGridRow" BasedOn="{StaticResource DgRow}">
                <Setter Property="MinHeight" Value="44"/>
            </Style>

            <!-- Status badge DataTemplate -->
            <DataTemplate x:Key="SyncStatusBadge">
                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#E8F0E0"/>
                            <Setter Property="ToolTip" Value="In sync with reference link"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSyncMismatch}" Value="True">
                                    <Setter Property="Background" Value="#FDEBD0"/>
                                    <Setter Property="ToolTip" Value="{Binding SyncWarning}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontSize="10" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="OK"/>
                                <Setter Property="Foreground" Value="#788c5d"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSyncMismatch}" Value="True">
                                        <Setter Property="Text" Value="Error"/>
                                        <Setter Property="Foreground" Value="#d97757"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </DataTemplate>

            <!-- Window-specific RadioButton sidebar nav -->
            <Style x:Key="NavBtn" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd" Background="Transparent"
                                    Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="4,1">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Overlay}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Accent}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SIDEBAR                                     -->
        <!-- ═══════════════════════════════════════════ -->
        <Border x:Name="SidebarBorder" Grid.Column="0" Background="{StaticResource Surface}" Visibility="{Binding ShowNav, Converter={StaticResource BoolToVis}}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="16,16,16,20">
                    <TextBlock Text="AllO" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="Toolkit" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="1,0,0,0"/>
                </StackPanel>

                <!-- Nav -->
                <StackPanel Margin="4,0">
                    <RadioButton Style="{StaticResource NavBtn}"
                                 IsChecked="{Binding IsCropTab, Mode=OneWay}"
                                 Checked="NavTab_Checked" Tag="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Copy Crop"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavBtn}"
                                 IsChecked="{Binding IsGridTab, Mode=OneWay}"
                                 Checked="NavTab_Checked" Tag="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Grids"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavBtn}"
                                 IsChecked="{Binding IsLevelTab, Mode=OneWay}"
                                 Checked="NavTab_Checked" Tag="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Levels"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ TAB 0: COPY CROP ═══ -->
            <Grid Grid.Row="0" Style="{StaticResource PanelSwap}" Visibility="{Binding IsCropTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Copy Crop" Style="{StaticResource BtnPrimary}" Command="{Binding CopyCropCommand}" Margin="0,0,8,0" ToolTip="Copy crop region from source view to selected targets"/>
                        <Button Content="Select All" Style="{StaticResource BtnSecondary}" Command="{Binding CropSelectAllCommand}" Margin="0,0,4,0" ToolTip="Select all views"/>
                        <Button Content="Select None" Style="{StaticResource BtnSecondary}" Command="{Binding CropSelectNoneCommand}" Margin="0,0,16,0" ToolTip="Deselect all views"/>
                        <TextBox Style="{StaticResource SearchBox}" Width="200"
                                 Text="{Binding CropSearch, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Source selection -->
                <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="BASE SOURCE VIEW" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Style="{StaticResource DarkCombo}" Width="350"
                                  ItemsSource="{Binding CropViews}"
                                  SelectedItem="{Binding CropSourceView}"
                                  DisplayMemberPath="Name"
                                  ItemContainerStyle="{StaticResource DarkComboItem}"/>
                        <TextBlock Text="→  Select targets below" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Target views list -->
                <DataGrid Grid.Row="2" x:Name="CropDataGrid"
                          ItemsSource="{Binding CropViewsView}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource DataGridGridLine}"
                          Background="{StaticResource Deep}" BorderThickness="0"
                          RowBackground="{StaticResource DataGridRowEven}" AlternatingRowBackground="{StaticResource DataGridRowOdd}"
                          Foreground="{StaticResource TextPrimary}" FontSize="12.5"
                          RowHeight="36" ColumnHeaderHeight="32"
                          ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                          CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="View Name" Width="*" Binding="{Binding Name}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Type" Width="120" Binding="{Binding ViewType}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Crop Active" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="No"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCropActive}" Value="True">
                                                        <Setter Property="Text" Value="Yes"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Status" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Done">
                                                        <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Applying...">
                                                        <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="2" Background="{StaticResource Deep}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=CropDataGrid, Path=Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource EmptyStateIcon}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No views available" Foreground="{StaticResource EmptyStateText}" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ TAB 1: GRIDS ═══ -->
            <Grid Grid.Row="0" Style="{StaticResource PanelSwap}" Visibility="{Binding IsGridTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Rename" Style="{StaticResource BtnPrimary}" Command="{Binding RenameGridsCommand}" Margin="0,0,8,0" ToolTip="Apply new names to selected grids"/>
                        <Button Content="Delete Selected" Style="{StaticResource BtnDanger}" Command="{Binding DeleteGridsCommand}" Margin="0,0,8,0" ToolTip="Delete selected grids from the document"/>
                        <Button Content="Select All" Style="{StaticResource BtnSecondary}" Command="{Binding GridSelectAllCommand}" Margin="0,0,4,0" ToolTip="Select all grids"/>
                        <Button Content="Select None" Style="{StaticResource BtnSecondary}" Command="{Binding GridSelectNoneCommand}" Margin="0,0,16,0" ToolTip="Deselect all grids"/>
                        <TextBox Style="{StaticResource SearchBox}" Width="200"
                                 Text="{Binding GridSearch, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Reference link + copy -->
                <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="REFERENCE LINK" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Style="{StaticResource DarkCombo}" Width="280"
                                  ItemsSource="{Binding ReferenceLinks}"
                                  SelectedItem="{Binding SelectedReferenceLink}"
                                  DisplayMemberPath="Name"
                                  ItemContainerStyle="{StaticResource DarkComboItem}"/>
                        <Button Content="Copy from link" Style="{StaticResource BtnPrimary}" Command="{Binding CopyGridsFromLinkCommand}" Margin="12,0,6,0" ToolTip="Copy all grids from the linked model into the host document"/>
                        <Button Content="Copy new only" Style="{StaticResource BtnSecondary}" Command="{Binding CopyNewGridsOnlyCommand}" Margin="0,0,6,0" ToolTip="Copy only grids that don't already exist in the host"/>
                        <Button Content="Sync from link" Style="{StaticResource BtnSecondary}" Command="{Binding SyncGridsFromLinkCommand}" ToolTip="Replace host grid geometry when it differs from the link"/>
                    </StackPanel>
                </Border>

                <!-- Prefix/Suffix -->
                <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="PREFIX:" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Style="{StaticResource SearchBox}" Width="100" Text="{Binding GridPrefix, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,0"/>
                        <TextBlock Text="SUFFIX:" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Style="{StaticResource SearchBox}" Width="100" Text="{Binding GridSuffix, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                        <Button Content="Apply to Selected" Style="{StaticResource BtnSecondary}" Command="{Binding ApplyGridPrefixSuffixCommand}" ToolTip="Apply prefix and suffix to selected grids"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="3" x:Name="GridsDataGrid"
                          ItemsSource="{Binding GridsView}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource DataGridGridLine}"
                          Background="{StaticResource Deep}" BorderThickness="0"
                          RowBackground="{StaticResource DataGridRowEven}" AlternatingRowBackground="{StaticResource DataGridRowOdd}"
                          Foreground="{StaticResource TextPrimary}" FontSize="12.5"
                          ColumnHeaderHeight="32"
                          ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                          CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRSync}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Name" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextAccent}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Status" Width="70" CellTemplate="{StaticResource SyncStatusBadge}"/>
                        <DataGridTextColumn Header="New Name" Width="150" Binding="{Binding NewName, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="{StaticResource Card}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Orientation" Width="120" Binding="{Binding Orientation}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Length (m)" Width="100" Binding="{Binding Length, StringFormat=F2}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="3" Background="{StaticResource Deep}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=GridsDataGrid, Path=Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource EmptyStateIcon}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No grids found in the document" Foreground="{StaticResource EmptyStateText}" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ TAB 2: LEVELS ═══ -->
            <Grid Grid.Row="0" Style="{StaticResource PanelSwap}" Visibility="{Binding IsLevelTab, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Rename" Style="{StaticResource BtnPrimary}" Command="{Binding RenameLevelsCommand}" Margin="0,0,6,0" ToolTip="Apply new names to selected levels"/>
                        <Button Content="Move" Style="{StaticResource BtnPrimary}" Command="{Binding MoveLevelsCommand}" Margin="0,0,6,0" ToolTip="Move selected levels by the elevation offset"/>
                        <Button Content="Delete Selected" Style="{StaticResource BtnDanger}" Command="{Binding DeleteLevelsCommand}" Margin="0,0,8,0" ToolTip="Delete selected levels from the document"/>
                        <Button Content="Select All" Style="{StaticResource BtnSecondary}" Command="{Binding LevelSelectAllCommand}" Margin="0,0,4,0" ToolTip="Select all levels"/>
                        <Button Content="Select None" Style="{StaticResource BtnSecondary}" Command="{Binding LevelSelectNoneCommand}" Margin="0,0,16,0" ToolTip="Deselect all levels"/>
                        <TextBox Style="{StaticResource SearchBox}" Width="200"
                                 Text="{Binding LevelSearch, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Reference link + copy -->
                <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="REFERENCE LINK" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Style="{StaticResource DarkCombo}" Width="280"
                                  ItemsSource="{Binding ReferenceLinks}"
                                  SelectedItem="{Binding SelectedReferenceLink}"
                                  DisplayMemberPath="Name"
                                  ItemContainerStyle="{StaticResource DarkComboItem}"/>
                        <Button Content="Copy from link" Style="{StaticResource BtnPrimary}" Command="{Binding CopyLevelsFromLinkCommand}" Margin="12,0,6,0" ToolTip="Copy all levels from the linked model into the host document"/>
                        <Button Content="Copy new only" Style="{StaticResource BtnSecondary}" Command="{Binding CopyNewLevelsOnlyCommand}" Margin="0,0,6,0" ToolTip="Copy only levels that don't already exist in the host"/>
                        <Button Content="Sync from link" Style="{StaticResource BtnSecondary}" Command="{Binding SyncLevelsFromLinkCommand}" ToolTip="Move host levels to match linked elevations when they differ"/>
                    </StackPanel>
                </Border>

                <!-- Offset -->
                <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,10"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ELEVATION OFFSET (m):" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Style="{StaticResource SearchBox}" Width="100" Text="{Binding ElevationOffset, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                        <Button Content="Apply to Selected" Style="{StaticResource BtnSecondary}" Command="{Binding ApplyElevationOffsetCommand}" ToolTip="Apply elevation offset to selected levels"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="3" x:Name="LevelsDataGrid"
                          ItemsSource="{Binding LevelsView}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource DataGridGridLine}"
                          Background="{StaticResource Deep}" BorderThickness="0"
                          RowBackground="{StaticResource DataGridRowEven}" AlternatingRowBackground="{StaticResource DataGridRowOdd}"
                          Foreground="{StaticResource TextPrimary}" FontSize="12.5"
                          ColumnHeaderHeight="32"
                          ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                          CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRSync}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Name" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextAccent}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Status" Width="70" CellTemplate="{StaticResource SyncStatusBadge}"/>
                        <DataGridTextColumn Header="New Name" Width="150" Binding="{Binding NewName, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="{StaticResource Card}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Elevation (m)" Width="120" Binding="{Binding Elevation, StringFormat=F3}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="New Elevation" Width="120" Binding="{Binding NewElevation, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="{StaticResource Card}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Structural" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value=""/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStructural}" Value="True">
                                                        <Setter Property="Text" Value="Structural"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Warning}"/>
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="3" Background="{StaticResource Deep}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=LevelsDataGrid, Path=Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource EmptyStateIcon}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No levels found in the document" Foreground="{StaticResource EmptyStateText}" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ PROGRESS ═══ -->
            <Border Grid.Row="1" Background="{StaticResource StatusBarBg}" Padding="20,6,20,4"
                    Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
                <ProgressBar Height="6" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                             Foreground="{StaticResource Orange}" Background="{StaticResource Surface}" BorderThickness="0"/>
            </Border>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="{StaticResource StatusBarBg}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11.5"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="Refresh" Style="{StaticResource BtnSecondary}"
                            Command="{Binding RefreshCommand}" FontSize="11" Padding="10,5" ToolTip="Reload data from the current document"/>
                    <Button Grid.Column="3" Content="Close" Style="{StaticResource BtnSecondary}"
                            Command="{Binding CloseCommand}" FontSize="11" Padding="12,5" ToolTip="Close the toolkit"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
