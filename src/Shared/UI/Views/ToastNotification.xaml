<UserControl x:Class="AllO.UI.Views.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Border x:Name="Root"
            Background="{StaticResource Card}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="14,10"
            MinWidth="260" MaxWidth="380"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="2" Opacity="0.45"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border x:Name="IconBox" Width="6" Height="34"
                    Background="{StaticResource Success}"
                    CornerRadius="3" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Foreground="{StaticResource TextPrimary}"
                           FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Name="BodyText"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
