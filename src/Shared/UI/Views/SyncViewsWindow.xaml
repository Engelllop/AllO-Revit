<Window x:Class="AllO.UI.Views.SyncViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Sync Views"
        Style="{StaticResource AllOWindow}"
        Height="290" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource Deep}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sync Views" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,2"/>
        <TextBlock Grid.Row="1" Text="The slave view follows the master view as you navigate. Run the command again to stop."
                   FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="2" Text="MASTER VIEW (you navigate)" Style="{StaticResource Lbl}"/>
        <ComboBox Grid.Row="3" Style="{StaticResource DarkCombo}" ItemContainerStyle="{StaticResource DarkComboItem}"
                  ItemsSource="{Binding Views}" SelectedItem="{Binding SelectedMaster}" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4" Text="SLAVE VIEW (follows)" Style="{StaticResource Lbl}"/>
        <ComboBox Grid.Row="5" Style="{StaticResource DarkCombo}" ItemContainerStyle="{StaticResource DarkComboItem}"
                  ItemsSource="{Binding Views}" SelectedItem="{Binding SelectedSlave}"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource BtnSecondary}" FontSize="12" Padding="18,6"
                    Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Start sync" Style="{StaticResource BtnPrimary}" FontSize="12" Padding="18,6"
                    IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
