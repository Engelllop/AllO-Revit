<Window x:Class="AllO.UI.Views.ReorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Re-Ordering Preview"
        Height="620" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource Deep}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Re-Ordering Preview" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Adjust prefix, start number and suffix. The preview updates in real time."
                   FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource SearchBox}"
                     Text="{Binding ParameterName, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Parameter name to write (e.g. Mark)" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Style="{StaticResource SearchBox}" Width="70"
                     Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Prefix" Margin="0,0,6,0"/>
            <TextBox Grid.Column="2" Style="{StaticResource SearchBox}" Width="60"
                     Text="{Binding StartNumber, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Start number" Margin="0,0,6,0"/>
            <TextBox Grid.Column="3" Style="{StaticResource SearchBox}" Width="70"
                     Text="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Suffix"/>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource Card}" CornerRadius="8"
                BorderBrush="{StaticResource Border}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,8">
                    <Button Content="Select All" Style="{StaticResource BtnSecondary}" FontSize="11"
                            Command="{Binding SelectAllCommand}" Padding="10,4" Margin="0,0,6,0"/>
                    <Button Content="Select None" Style="{StaticResource BtnSecondary}" FontSize="11"
                            Command="{Binding SelectNoneCommand}" Padding="10,4"/>
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          Background="Transparent" BorderThickness="0"
                          RowBackground="{StaticResource DataGridRowEven}"
                          AlternatingRowBackground="{StaticResource DataGridRowOdd}"
                          Foreground="{StaticResource TextPrimary}" FontSize="12"
                          ColumnHeaderHeight="28"
                          ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                          CellStyle="{StaticResource DgCell}">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="" Width="40" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                CanUserResize="False"/>
                        <DataGridTextColumn Header="Element" Width="180" Binding="{Binding ElementName}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Category" Width="110" Binding="{Binding Category}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Current" Width="90" Binding="{Binding CurrentValue}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Preview" Width="90" Binding="{Binding PreviewValue}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnSecondary}" FontSize="12"
                    Command="{Binding CancelCommand}" Padding="18,6" Margin="0,0,8,0"/>
            <Button Content="Apply Re-Ordering" Style="{StaticResource BtnPrimary}" FontSize="12"
                    Command="{Binding ExecuteCommand}" Padding="18,6"/>
        </StackPanel>
    </Grid>
</Window>
