<Window x:Class="AllO.UI.Views.ColorCoderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AllO — Color Coder"
        Height="560" Width="440"
        MinHeight="480" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#1A1A1A">

    <Window.Resources>
        <SolidColorBrush x:Key="Surface"  Color="#252525"/>
        <SolidColorBrush x:Key="Card"     Color="#2C2C2C"/>
        <SolidColorBrush x:Key="CardH"    Color="#383838"/>
        <SolidColorBrush x:Key="Bdr"      Color="#3A3A3A"/>
        <SolidColorBrush x:Key="Txt"      Color="#E8E8E8"/>
        <SolidColorBrush x:Key="Txt2"     Color="#9A9A9A"/>
        <SolidColorBrush x:Key="TxtM"     Color="#6E6E6E"/>
        <SolidColorBrush x:Key="Acc"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="AccH"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Suc"      Color="#34D399"/>

        <Style x:Key="BtnP" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Acc}"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccH}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnS" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Card}"/>
            <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardH}"/>
                                <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5A5A5A"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Compact mode toggle -->
        <Style x:Key="ModeToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,0,0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1"
                Padding="22,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AllO" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Acc}"/>
                    <Border Background="#1A2E1A" CornerRadius="6" Padding="8,3" Margin="12,4,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ON" FontSize="10" Foreground="{StaticResource Suc}" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Color Coder — settings" FontSize="11" Foreground="{StaticResource TxtM}" Margin="1,0,0,0"/>
                <TextBlock Text="First ribbon click turns colors on. Second click opens this panel."
                           FontSize="12" Foreground="{StaticResource Txt2}" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,18">
            <StackPanel>

                <TextBlock Text="HIGHLIGHT STYLE" Style="{StaticResource Lbl}"/>
                <Border Background="{StaticResource Card}" CornerRadius="8" BorderBrush="{StaticResource Bdr}"
                        BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                     IsChecked="{Binding ModeFill}">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Txt}">
                                <Run FontWeight="SemiBold" Text="Top bar"/><Run Text=" — "/>
                                <Run Text="Strong strip along the top of the view (best for a single host model)."/>
                            </TextBlock>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                     IsChecked="{Binding ModeBorder}">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Txt}">
                                <Run FontWeight="SemiBold" Text="Border"/><Run Text=" — "/>
                                <Run Text="Outline around the whole view area."/>
                            </TextBlock>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                     IsChecked="{Binding ModeLine}">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Txt}">
                                <Run FontWeight="SemiBold" Text="Bottom line"/><Run Text=" — "/>
                                <Run Text="Thin strip along the bottom."/>
                            </TextBlock>
                        </RadioButton>
                        <TextBlock Text="{Binding DisplayModeDescription}" FontSize="11" Foreground="{StaticResource TxtM}"
                                   Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="INTENSITY" Style="{StaticResource Lbl}" Margin="0,18,0,0"/>
                <Border Background="{StaticResource Card}" CornerRadius="8" BorderBrush="{StaticResource Bdr}"
                        BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Opacity" FontSize="12" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0.15" Maximum="1.0"
                                    Value="{Binding Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="14,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Opacity, StringFormat='{}{0:P0}'}"
                                       FontSize="12" Foreground="{StaticResource Txt2}" Width="40" TextAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Thickness" FontSize="12" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="2" Maximum="14"
                                    Value="{Binding BarThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    IsSnapToTickEnabled="True" TickFrequency="1" Margin="14,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding BarThickness, StringFormat='{}{0:0}px'}"
                                       FontSize="12" Foreground="{StaticResource Txt2}" Width="40" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#161616" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Padding="22,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TxtM}"
                           TextWrapping="Wrap"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Reset (off)" Style="{StaticResource BtnS}" FontSize="12" Padding="16,8"
                            Command="{Binding ResetCommand}" Margin="0,0,10,0"
                            ToolTip="Turn Color Coder off and remove all tint overlays"/>
                    <Button Content="Close" Style="{StaticResource BtnP}" Command="{Binding CloseCommand}" FontSize="12" Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
