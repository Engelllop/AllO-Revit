<Window x:Class="AllO.UI.Views.ColorCoderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AllO — Color Coder"
        Height="620" Width="520"
        MinHeight="500" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#15151E">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg"      Color="#15151E"/>
        <SolidColorBrush x:Key="Surface"  Color="#1B1B28"/>
        <SolidColorBrush x:Key="Card"     Color="#1E1E32"/>
        <SolidColorBrush x:Key="CardH"    Color="#252542"/>
        <SolidColorBrush x:Key="Bdr"      Color="#2A2A42"/>
        <SolidColorBrush x:Key="Txt"      Color="#E8E8F0"/>
        <SolidColorBrush x:Key="Txt2"     Color="#9999B3"/>
        <SolidColorBrush x:Key="TxtM"     Color="#666680"/>
        <SolidColorBrush x:Key="Acc"      Color="#6C63FF"/>
        <SolidColorBrush x:Key="AccH"     Color="#5B53E8"/>
        <SolidColorBrush x:Key="Suc"      Color="#34D399"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Toggle Button Style (Radio-like) -->
        <Style x:Key="ToggleMode" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{StaticResource Card}"
                                BorderBrush="{StaticResource Bdr}" BorderThickness="1"
                                CornerRadius="8" Padding="16,14" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon area -->
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8">
                                    <Border.Background>
                                        <SolidColorBrush Color="#252545"/>
                                    </Border.Background>
                                    <ContentPresenter Content="{TemplateBinding Tag}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Text -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Check indicator -->
                                <Border x:Name="Check" Grid.Column="3" Width="20" Height="20"
                                        CornerRadius="10" Background="#252545"
                                        VerticalAlignment="Center">
                                    <Ellipse x:Name="Dot" Width="10" Height="10" Fill="Transparent"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Acc}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1C1C38"/>
                                <Setter TargetName="Check" Property="Background" Value="{StaticResource Acc}"/>
                                <Setter TargetName="Dot" Property="Fill" Value="White"/>
                                <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardH}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="BtnP" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Acc}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccH}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnS" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Card}"/>
            <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardH}"/>
                                <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ═══════ HEADER ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="AllO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Acc}"/>
                    <TextBlock Text="Color Coder" FontSize="10" Foreground="{StaticResource TxtM}" Margin="1,0,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Shuffle Colors" Style="{StaticResource BtnS}" FontSize="11" Padding="10,6"
                            Command="{Binding RandomizeColorsCommand}" Margin="0,0,8,0"/>
                    <Button Content="Refresh" Style="{StaticResource BtnS}" FontSize="11" Padding="10,6"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ CONTENT ═══════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,12">
            <StackPanel>

                <!-- ── DOCUMENTS LIST ── -->
                <TextBlock Text="OPEN DOCUMENTS" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TxtM}" Margin="0,0,0,10"/>

                <ItemsControl ItemsSource="{Binding Documents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Card}" CornerRadius="8"
                                    BorderBrush="{StaticResource Bdr}" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Color swatch (clickable to cycle) -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                            Background="{Binding ColorBrush}" Opacity="0.9">
                                        <TextBlock Text="{Binding DocumentName[0]}" FontSize="16" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Doc info -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DocumentName}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#E8E8F0"/>
                                            <Border Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"
                                                    Background="#1A3A2A" CornerRadius="8" Padding="8,2" Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="Active" FontSize="9" Foreground="#34D399" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding ViewCount, StringFormat='{}{0} open views'}"
                                                       FontSize="11" Foreground="#666680"/>
                                            <TextBlock Text="  ·  " FontSize="11" Foreground="#444460"/>
                                            <TextBlock Text="{Binding ColorHex}" FontSize="11" Foreground="#666680" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Color swatches for quick pick -->
                                    <ItemsControl Grid.Column="3" ItemsSource="{Binding DataContext.PresetColors, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" MaxWidth="140"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="16" Height="16" CornerRadius="4" Margin="1" Cursor="Hand"
                                                        MouseLeftButtonDown="ColorSwatch_Click">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding}"/>
                                                    </Border.Background>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── DISPLAY MODE (Toggle Stack) ── -->
                <TextBlock Text="DISPLAY MODE" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TxtM}" Margin="0,20,0,10"/>

                <StackPanel>
                    <RadioButton Style="{StaticResource ToggleMode}" GroupName="DisplayMode"
                                 IsChecked="{Binding ModeFill}">
                        <RadioButton.Tag>
                            <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#9B93FF"/>
                        </RadioButton.Tag>
                        <StackPanel>
                            <TextBlock Text="Fill Bar" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Full colored bar across the top of each view" FontSize="11"
                                       Foreground="#666680" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource ToggleMode}" GroupName="DisplayMode"
                                 IsChecked="{Binding ModeBorder}">
                        <RadioButton.Tag>
                            <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#38BDF8"/>
                        </RadioButton.Tag>
                        <StackPanel>
                            <TextBlock Text="Border" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Colored border around each view window" FontSize="11"
                                       Foreground="#666680" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource ToggleMode}" GroupName="DisplayMode"
                                 IsChecked="{Binding ModeLine}">
                        <RadioButton.Tag>
                            <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#34D399"/>
                        </RadioButton.Tag>
                        <StackPanel>
                            <TextBlock Text="Bottom Line" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Subtle colored line at the bottom of each view" FontSize="11"
                                       Foreground="#666680" Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- ── SETTINGS ── -->
                <TextBlock Text="SETTINGS" FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource TxtM}" Margin="0,20,0,10"/>

                <Border Background="{StaticResource Card}" CornerRadius="8"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="1"
                        Padding="16,14">
                    <StackPanel>
                        <!-- Opacity -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Opacity" FontSize="12" Foreground="#9999B3"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0.1" Maximum="1.0"
                                    Value="{Binding Opacity}" Margin="16,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Opacity, StringFormat='{}{0:P0}'}"
                                       FontSize="12" Foreground="#9999B3" FontFamily="Consolas"
                                       VerticalAlignment="Center" Width="40" TextAlignment="Right"/>
                        </Grid>

                        <!-- Thickness -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Thickness" FontSize="12" Foreground="#9999B3"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="2" Maximum="12"
                                    Value="{Binding BarThickness}" Margin="16,0"
                                    VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBlock Grid.Column="2" Text="{Binding BarThickness, StringFormat='{}{0:0}px'}"
                                       FontSize="12" Foreground="#9999B3" FontFamily="Consolas"
                                       VerticalAlignment="Center" Width="40" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════ STATUS BAR ═══════ -->
        <Border Grid.Row="2" Background="#111119"
                BorderBrush="#1A1A2E" BorderThickness="0,1,0,0"
                Padding="20,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11.5"
                           Foreground="{StaticResource TxtM}" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="Close" Style="{StaticResource BtnS}"
                        Command="{Binding CloseCommand}" FontSize="11" Padding="12,5"/>
            </Grid>
        </Border>
    </Grid>
</Window>
