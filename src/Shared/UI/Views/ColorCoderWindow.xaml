<Window x:Class="AllO.UI.Views.ColorCoderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="AllO — Color Coder"
        Height="560" Width="440"
        MinHeight="480" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource Deep}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            NonClientFrameEdges="None"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Title-bar system buttons (min / max / close) -->
        <Style x:Key="ChromeSysBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ChromeBtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeCloseBtn" TargetType="Button" BasedOn="{StaticResource ChromeSysBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CloseHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,0,0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Deep}" BorderBrush="{StaticResource Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource Surface}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,8,0">
                    <TextBlock Text="AllO" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                    <TextBlock Text="Color Coder" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Border Background="{StaticResource SuccessDim}" CornerRadius="5" Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ON" FontSize="9" Foreground="{StaticResource Success}" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource ChromeSysBtn}" Click="Minimize_Click" ToolTip="Minimize"
                            Foreground="{StaticResource TextSecondary}">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource ChromeSysBtn}" Click="MaximizeRestore_Click"
                            Foreground="{StaticResource TextSecondary}">
                        <Button.ToolTip>
                            <ToolTip>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Maximize"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                                    <Setter Property="Text" Value="Restore"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </ToolTip>
                        </Button.ToolTip>
                        <TextBlock x:Name="MaximizeGlyph" FontFamily="Segoe MDL2 Assets" FontSize="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE922;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                            <Setter Property="Text" Value="&#xE923;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource ChromeCloseBtn}" Click="CloseChrome_Click" ToolTip="Close"
                            Foreground="{StaticResource TextSecondary}">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Sub-header -->
            <Border Grid.Row="1" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="22,12,22,14">
                <StackPanel>
                    <TextBlock Text="First ribbon click turns colors on. Second click opens this panel."
                               FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Text="About view tabs: "/>
                        <Run Text="Revit's API does not let add-ins paint the native view tab strip. Highlights are drawn on the drawing surface at the edge of the view window—not on Autodesk's tab control."/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="22,18">
                <StackPanel>

                    <TextBlock Text="HIGHLIGHT STYLE" Style="{StaticResource Lbl}"/>
                    <Border Background="{StaticResource Card}" CornerRadius="8" BorderBrush="{StaticResource Border}"
                            BorderThickness="1" Padding="14,12">
                        <StackPanel>
                            <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                         IsChecked="{Binding ModeFill}"
                                         ToolTip="Highlight elements with a diffuse glow from the top edge">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}">
                                    <Run FontWeight="SemiBold" Text="Top glow"/><Run Text=" — "/>
                                    <Run Text="Diffuse light from the top edge into the canvas — use Reach to control how far the glow spreads."/>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                         IsChecked="{Binding ModeBorder}"
                                         ToolTip="Draw an outline around the whole view area">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}">
                                    <Run FontWeight="SemiBold" Text="Border"/><Run Text=" — "/>
                                    <Run Text="Outline around the whole view area."/>
                                </TextBlock>
                            </RadioButton>
                            <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                         IsChecked="{Binding ModeLine}"
                                         ToolTip="Highlight elements with a diffuse glow from the bottom edge">
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}">
                                    <Run FontWeight="SemiBold" Text="Bottom glow"/><Run Text=" — "/>
                                    <Run Text="Same idea as top glow, rising from the bottom of the view."/>
                                </TextBlock>
                            </RadioButton>
                            <TextBlock Text="{Binding DisplayModeDescription}" FontSize="11" Foreground="{StaticResource TextMuted}"
                                       Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="INTENSITY" Style="{StaticResource Lbl}" Margin="0,18,0,0"/>
                    <Border Background="{StaticResource Card}" CornerRadius="8" BorderBrush="{StaticResource Border}"
                            BorderThickness="1" Padding="14,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Opacity" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" Minimum="0.15" Maximum="1.0"
                                        Value="{Binding Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="14,0"
                                        ToolTip="Adjust the opacity of the highlight overlay"/>
                                <TextBlock Grid.Column="2" Text="{Binding Opacity, StringFormat='{}{0:P0}'}"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Width="40" TextAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center">
                                    <Run Text="Reach"/><LineBreak/><Run Text="(glow depth)" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                </TextBlock>
                                <Slider Grid.Column="1" Minimum="2" Maximum="14"
                                        Value="{Binding BarThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsSnapToTickEnabled="True" TickFrequency="1" Margin="14,0"
                                        ToolTip="How far the glow extends into the view (scaled from this value)."/>
                                <TextBlock Grid.Column="2" Text="{Binding BarThickness, StringFormat='{}{0:0}'}"
                                           FontSize="12" Foreground="{StaticResource TextSecondary}" Width="32" TextAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="3" Background="{StaticResource StatusBarBg}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="22,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextMuted}"
                               TextWrapping="Wrap"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Reset (off)" Style="{StaticResource BtnSecondary}" FontSize="12" Padding="16,8"
                                Command="{Binding ResetCommand}" Margin="0,0,10,0"
                                ToolTip="Turn Color Coder off and remove all tint overlays"/>
                        <Button Content="Close" Style="{StaticResource BtnPrimary}" Command="{Binding CloseCommand}" FontSize="12" Padding="16,8" ToolTip="Close"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
