<Window x:Class="AllO.UI.Views.ColorCoderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AllO — Color Coder"
        Style="{StaticResource AllOWindow}"
        Height="560" Width="440"
        MinHeight="480" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource Deep}">

    <Window.Resources>
        <Style x:Key="ModeToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,0,0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sub-header -->
        <Border Grid.Row="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                Padding="22,12,22,14">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Background="{StaticResource SuccessDim}" CornerRadius="5" Padding="7,2" VerticalAlignment="Center">
                        <TextBlock Text="ON" FontSize="9" Foreground="{StaticResource Success}" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="Color Coder is active" FontSize="11" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock Text="First ribbon click turns colors on. Second click opens this panel."
                           FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,18">
            <StackPanel>

                <TextBlock Text="HIGHLIGHT STYLE" Style="{StaticResource Lbl}"/>
                <Border Background="{StaticResource Card}" CornerRadius="8" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                     IsChecked="{Binding ModeTabs}"
                                     ToolTip="Paint the native view tabs with each document's color">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}">
                                <Run FontWeight="SemiBold" Text="View tabs"/><Run Text=" — "/>
                                <Run Text="Colors the document tab strip itself, like NonicaTab. Active tab full color, inactive dimmed."/>
                            </TextBlock>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                     IsChecked="{Binding ModeFill}"
                                     ToolTip="Highlight elements with a diffuse glow from the top edge">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}">
                                <Run FontWeight="SemiBold" Text="Top glow"/><Run Text=" — "/>
                                <Run Text="Diffuse light from the top edge into the canvas — use Reach to control how far the glow spreads."/>
                            </TextBlock>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                     IsChecked="{Binding ModeBorder}"
                                     ToolTip="Draw an outline around the whole view area">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}">
                                <Run FontWeight="SemiBold" Text="Border"/><Run Text=" — "/>
                                <Run Text="Outline around the whole view area."/>
                            </TextBlock>
                        </RadioButton>
                        <RadioButton Style="{StaticResource ModeToggle}" GroupName="DisplayMode"
                                     IsChecked="{Binding ModeLine}"
                                     ToolTip="Highlight elements with a diffuse glow from the bottom edge">
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}">
                                <Run FontWeight="SemiBold" Text="Bottom glow"/><Run Text=" — "/>
                                <Run Text="Same idea as top glow, rising from the bottom of the view."/>
                            </TextBlock>
                        </RadioButton>
                        <TextBlock Text="{Binding DisplayModeDescription}" FontSize="11" Foreground="{StaticResource TextMuted}"
                                   Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="INTENSITY" Style="{StaticResource Lbl}" Margin="0,18,0,0"/>
                <Border Background="{StaticResource Card}" CornerRadius="8" BorderBrush="{StaticResource Border}"
                        BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Opacity" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0.15" Maximum="1.0"
                                    Value="{Binding Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="14,0"
                                    ToolTip="Adjust the opacity of the highlight overlay"/>
                            <TextBlock Grid.Column="2" Text="{Binding Opacity, StringFormat='{}{0:P0}'}"
                                       FontSize="12" Foreground="{StaticResource TextSecondary}" Width="40" TextAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="12" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center">
                                <Run Text="Reach"/><LineBreak/><Run Text="(glow depth)" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            </TextBlock>
                            <Slider Grid.Column="1" Minimum="2" Maximum="14"
                                    Value="{Binding BarThickness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    IsSnapToTickEnabled="True" TickFrequency="1" Margin="14,0"
                                    ToolTip="How far the glow extends into the view (scaled from this value)."/>
                            <TextBlock Grid.Column="2" Text="{Binding BarThickness, StringFormat='{}{0:0}'}"
                                       FontSize="12" Foreground="{StaticResource TextSecondary}" Width="32" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource StatusBarBg}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="22,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextMuted}"
                           TextWrapping="Wrap"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Reset (off)" Style="{StaticResource BtnSecondary}" FontSize="12" Padding="16,8"
                            Command="{Binding ResetCommand}" Margin="0,0,10,0"
                            ToolTip="Turn Color Coder off and remove all tint overlays"/>
                    <Button Content="Close" Style="{StaticResource BtnPrimary}" Command="{Binding CloseCommand}" FontSize="12" Padding="16,8" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
