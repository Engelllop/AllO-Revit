<Window x:Class="AllO.UI.Views.MatchParameterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Match Parameters"
        Height="600" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource Deep}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select Parameters to Copy" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Check the parameters you want to copy from the source element to the targets."
                   FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Select All" Style="{StaticResource BtnSecondary}" FontSize="11"
                    Command="{Binding SelectAllCommand}" Padding="10,4" Margin="0,0,6,0"/>
            <Button Content="Select Safe" Style="{StaticResource BtnSecondary}" FontSize="11"
                    Command="{Binding SelectSafeCommand}" Padding="10,4" Margin="0,0,6,0"
                    ToolTip="Select only parameters that are safe to copy (excludes ElementId references)"/>
            <Button Content="Select None" Style="{StaticResource BtnSecondary}" FontSize="11"
                    Command="{Binding SelectNoneCommand}" Padding="10,4"/>
        </StackPanel>

        <Border Grid.Row="3" Background="{StaticResource Card}" CornerRadius="8"
                BorderBrush="{StaticResource Border}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Parameters}"
                      AutoGenerateColumns="False" CanUserAddRows="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      Background="Transparent" BorderThickness="0"
                      RowBackground="{StaticResource DataGridRowEven}"
                      AlternatingRowBackground="{StaticResource DataGridRowOdd}"
                      Foreground="{StaticResource TextPrimary}" FontSize="12"
                      ColumnHeaderHeight="28"
                      ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                      CellStyle="{StaticResource DgCell}">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="" Width="40" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            CanUserResize="False"/>
                    <DataGridTextColumn Header="Parameter" Width="200" Binding="{Binding Name}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Type" Width="90" Binding="{Binding StorageType}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Value" Width="*" Binding="{Binding CurrentValue}" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnSecondary}" FontSize="12"
                    Command="{Binding CancelCommand}" Padding="18,6" Margin="0,0,8,0"/>
            <Button Content="Match to Selected Targets" Style="{StaticResource BtnPrimary}" FontSize="12"
                    Command="{Binding ExecuteCommand}" Padding="18,6"/>
        </StackPanel>
    </Grid>
</Window>
