<Window x:Class="AllO.UI.Views.FamilyExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Family Export"
        Style="{StaticResource AllOWindow}"
        Height="240" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource Deep}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Export Families" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Choose the destination folder for the .rfa files."
                   FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PathBox" Grid.Column="0" Style="{StaticResource SearchBox}"/>
            <Button Grid.Column="1" Content="Browse…" Style="{StaticResource BtnSecondary}" FontSize="12"
                    Padding="14,8" Margin="8,0,0,0" Click="Browse_Click"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource BtnSecondary}" FontSize="12"
                    Padding="18,6" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Export" Style="{StaticResource BtnPrimary}" FontSize="12"
                    Padding="18,6" Click="Export_Click"/>
        </StackPanel>
    </Grid>
</Window>
