<Window x:Class="AllO.UI.Views.PublishWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AllO — Publish"
        Height="780" Width="1060"
        MinHeight="650" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/AllO.Shared;component/UI/Styles/AllOTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Grid -->
            <RowDefinition Height="Auto"/>   <!-- Settings -->
            <RowDefinition Height="Auto"/>   <!-- Progress -->
            <RowDefinition Height="Auto"/>   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- HEADER BAR                                                -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                Padding="20,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="AllO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="Publish" FontSize="10" Foreground="{StaticResource TextMuted}" Margin="1,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="{Binding DocumentName}" FontSize="12"
                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>

                <Button Grid.Column="4" Content="Select All" Style="{StaticResource BtnSecondary}" FontSize="11" Padding="10,5"
                        Command="{Binding SelectAllCommand}" ToolTip="Select all sheets"/>
                <Button Grid.Column="6" Content="Select None" Style="{StaticResource BtnSecondary}" FontSize="11" Padding="10,5"
                        Command="{Binding SelectNoneCommand}" ToolTip="Deselect all sheets"/>

                <Grid Grid.Column="8" MinWidth="240">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" MinWidth="160" Margin="0,0,6,0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search by sheet number or name"/>
                    <Grid Grid.Column="1">
                        <Button x:Name="FilterSheetBtn" Style="{StaticResource BtnSecondary}" Width="36" Padding="0"
                                Command="{Binding ToggleFilterPopupCommand}"
                                ToolTip="Filter by any sheet parameter (shared parameters, discipline, etc.)">
                            <Grid Width="18" Height="18">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71C;" FontSize="15"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}"/>
                                <Ellipse Width="6" Height="6" HorizontalAlignment="Right" VerticalAlignment="Top"
                                         Margin="0,-3,-2,0" Fill="{StaticResource Accent}"
                                         Visibility="{Binding HasParameterFilter, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>
                        <Popup PlacementTarget="{Binding ElementName=FilterSheetBtn}" Placement="Bottom"
                               IsOpen="{Binding IsFilterPopupOpen, Mode=TwoWay}" StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="#2C2C2C" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" MinWidth="280"
                                    SnapsToDevicePixels="True">
                                <StackPanel>
                                    <TextBlock Text="FILTER BY PARAMETER" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Parameter" Style="{StaticResource Lbl}" Margin="0,0,0,4"/>
                                    <ComboBox Style="{StaticResource DarkCombo}"
                                              ItemsSource="{Binding FilterParameterNames}"
                                              SelectedItem="{Binding SelectedFilterParameter}"
                                              ItemContainerStyle="{StaticResource DarkComboItem}"/>
                                    <TextBlock Text="Value" Style="{StaticResource Lbl}" Margin="0,10,0,4"/>
                                    <ComboBox Style="{StaticResource DarkCombo}"
                                              ItemsSource="{Binding FilterValueOptions}"
                                              SelectedItem="{Binding SelectedFilterValue}"
                                              ItemContainerStyle="{StaticResource DarkComboItem}"/>
                                    <TextBlock Text="&quot;Any value&quot; keeps all sheets that have the parameter."
                                               Foreground="{StaticResource TextMuted}" FontSize="10" TextWrapping="Wrap"
                                               Margin="0,8,0,10"/>
                                    <Button Content="Clear filter" Style="{StaticResource BtnSecondary}" HorizontalAlignment="Left"
                                            Command="{Binding ClearSheetFilterCommand}" FontSize="11" Padding="12,6"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SHEET LIST                                                -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="1" x:Name="SheetsDataGrid"
                  ItemsSource="{Binding SheetsView}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Extended" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#272727"
                  Background="{StaticResource Deep}" BorderThickness="0"
                  RowBackground="#252525" AlternatingRowBackground="#2B2B2B"
                  Foreground="{StaticResource TextPrimary}" FontSize="12.5"
                  RowHeight="36" ColumnHeaderHeight="32"
                  ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                  CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}">
            <DataGrid.Resources>
                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource DarkComboItem}"/>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Number" Width="100" Binding="{Binding SheetNumber}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{StaticResource TextAccent}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Sheet Name" Width="*" Binding="{Binding SheetName}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Output File Name" Width="*" Binding="{Binding FileName}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="FontStyle" Value="Italic"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Status" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#333333"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Done">
                                                <Setter Property="Background" Value="#1A2E1A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                <Setter Property="Background" Value="#2E1A1A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}" FontSize="11" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Done">
                                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                    <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="PDF Failed">
                                                    <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="DWG Failed">
                                                    <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="1" Background="{StaticResource Deep}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=SheetsDataGrid, Path=Items.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#484848" HorizontalAlignment="Center"/>
                <TextBlock Text="No sheets to publish" Foreground="#787878" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="Try clearing filters or selecting sheets" Foreground="#686868" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SETTINGS PANEL (cards layout)                             -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#161616"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                Padding="16,14,16,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ── Card 1: PDF Settings ── -->
                <Border Grid.Column="0" Background="#2C2C2C" CornerRadius="8"
                        BorderBrush="#353535" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox IsChecked="{Binding ExportPdf}"
                                      Style="{StaticResource DkCheck}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="PDF" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="80"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*" MinWidth="100"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*" MinWidth="90"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="COLOR" Style="{StaticResource Lbl}"/>
                                <ComboBox Style="{StaticResource DarkCombo}"
                                          ItemsSource="{Binding ColorModes}"
                                          SelectedItem="{Binding SelectedColorMode}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"
                                          ToolTip="PDF color mode"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="QUALITY" Style="{StaticResource Lbl}"/>
                                <ComboBox Style="{StaticResource DarkCombo}"
                                          ItemsSource="{Binding Qualities}"
                                          SelectedItem="{Binding SelectedQuality}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"
                                          ToolTip="Raster image quality"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="PAPER SIZE" Style="{StaticResource Lbl}"/>
                                <ComboBox Style="{StaticResource DarkCombo}"
                                          ItemsSource="{Binding PaperSizes}"
                                          SelectedItem="{Binding SelectedPaperSize}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"
                                          ToolTip="Output paper size"/>
                            </StackPanel>
                        </Grid>

                        <CheckBox Content="Combine all sheets into single PDF" IsChecked="{Binding CombinePdf}"
                                  Style="{StaticResource DkCheck}" Margin="0,10,0,0" FontSize="11"
                                  ToolTip="Merge all exported sheets into a single PDF file"/>
                    </StackPanel>
                </Border>

                <!-- ── Card 2: DWG Settings + Output ── -->
                <Border Grid.Column="2" Background="#2C2C2C" CornerRadius="8"
                        BorderBrush="#353535" BorderThickness="1" Padding="14,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <CheckBox IsChecked="{Binding ExportDwg}"
                                      Style="{StaticResource DkCheck}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="DWG" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="UNITS" Style="{StaticResource Lbl}"/>
                                <ComboBox Style="{StaticResource DarkCombo}"
                                          ItemsSource="{Binding DwgUnits}"
                                          SelectedItem="{Binding SelectedDwgUnit}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"
                                          ToolTip="DWG export units"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="VERSION" Style="{StaticResource Lbl}"/>
                                <ComboBox Style="{StaticResource DarkCombo}"
                                          ItemsSource="{Binding DwgVersions}"
                                          SelectedItem="{Binding SelectedDwgVersion}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"
                                          ToolTip="AutoCAD version compatibility"/>
                            </StackPanel>
                        </Grid>

                        <!-- Output settings in same card -->
                        <Border Height="1" Background="#353535" Margin="0,12,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="NAMING PATTERN" Style="{StaticResource Lbl}"/>
                                <TextBox Style="{StaticResource SearchBox}"
                                         Text="{Binding NamingPattern, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Use {number} and {name} as placeholders"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <CheckBox Content="Create subfolders (PDF/ DWG/)" IsChecked="{Binding CreateSubfolders}"
                                          Style="{StaticResource DkCheck}" FontSize="11"
                                          ToolTip="Organize exports into separate PDF and DWG folders"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Card 3: Output + Publish ── -->
                <Border Grid.Column="4" Background="#2C2C2C" CornerRadius="8"
                        BorderBrush="#353535" BorderThickness="1" Padding="14,12"
                        MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="OUTPUT FOLDER" Style="{StaticResource Lbl}" Margin="0,0,0,5"/>
                        <TextBox Style="{StaticResource SearchBox}"
                                 Text="{Binding OutputFolder}" IsReadOnly="True"
                                 TextWrapping="NoWrap" FontSize="11"/>

                        <Button Content="Browse Folder" Style="{StaticResource BtnSecondary}"
                                Command="{Binding BrowseFolderCommand}" Margin="0,8,0,0"
                                HorizontalAlignment="Stretch" FontSize="11" Padding="8,7"
                                ToolTip="Choose the output folder for exported files"/>

                        <Border Height="1" Background="#353535" Margin="0,12,0,12"/>

                        <!-- PUBLISH BUTTON -->
                        <Button Style="{StaticResource BtnPrimary}" Command="{Binding PublishCommand}"
                                HorizontalAlignment="Stretch"
                                ToolTip="Export selected sheets to PDF and/or DWG">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Publish" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding SelectedCount, StringFormat=' ({0})'}"
                                           FontSize="14" Opacity="0.6"/>
                            </StackPanel>
                        </Button>

                        <!-- CANCEL BUTTON (visible solo durante el export) -->
                        <Button Style="{StaticResource BtnSecondary}" Command="{Binding CancelExportCommand}"
                                HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                Content="Cancel export"
                                ToolTip="Stop after the current sheet"
                                Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PROGRESS BAR                                              -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <ProgressBar Grid.Row="3" Height="4"
                     Minimum="0"
                     Maximum="{Binding ProgressMax}"
                     Value="{Binding ProgressValue}"
                     Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}"
                     Background="#1A1A1A" BorderThickness="0">
            <ProgressBar.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#E0E0E0" Offset="0"/>
                    <GradientStop Color="#FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#E0E0E0" Offset="1"/>
                </LinearGradientBrush>
            </ProgressBar.Foreground>
        </ProgressBar>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR                                                -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#1A1A1A"
                BorderBrush="#272727" BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextSecondary}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Path="VisibleSheetCount"/>
                                <Binding Path="TotalInDocument"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text=" sheets" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="#323232" Margin="8,2"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{Binding SelectedCount}" FontWeight="SemiBold" FontSize="12"
                               Foreground="{StaticResource TextAccent}"/>
                    <TextBlock Text=" selected" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                </StackPanel>

                <TextBlock Grid.Column="4" Text="{Binding StatusMessage}" FontSize="11.5"
                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="6" Style="{StaticResource BtnSecondary}" FontSize="11" Padding="10,5"
                        Command="{Binding OpenFolderCommand}"
                        ToolTip="Open the output folder in File Explorer">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Open Folder"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="8" Content="Close" Style="{StaticResource BtnSecondary}"
                        Command="{Binding CloseCommand}" FontSize="11" Padding="12,5"
                        ToolTip="Close the publish window"/>
            </Grid>
        </Border>
    </Grid>
</Window>
