<Window x:Class="AllO.UI.Views.ParameterPushWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Parameter Push"
        Style="{StaticResource AllOWindow}"
        Height="250" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource Deep}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Parameter Push" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,2"/>
        <TextBlock Grid.Row="1" Text="Pick the parameter to copy from the source, then select the target elements."
                   FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="2" Text="PARAMETER" Style="{StaticResource Lbl}"/>
        <ComboBox Grid.Row="3" Style="{StaticResource DarkCombo}" ItemContainerStyle="{StaticResource DarkComboItem}"
                  ItemsSource="{Binding Parameters}" SelectedItem="{Binding SelectedParameter}"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource BtnSecondary}" FontSize="12" Padding="18,6"
                    Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Pick targets" Style="{StaticResource BtnPrimary}" FontSize="12" Padding="18,6"
                    IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
