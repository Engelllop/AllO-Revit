<Window x:Class="AllO.UI.Views.SheetManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AllO — Sheet Manager"
        Height="780" Width="1200"
        MinHeight="600" MinWidth="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E">

    <Window.Resources>

        <!-- COLOR PALETTE -->
        <SolidColorBrush x:Key="DeepBrush"       Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#252525"/>
        <SolidColorBrush x:Key="PanelBrush"       Color="#292929"/>
        <SolidColorBrush x:Key="CardBrush"        Color="#303030"/>
        <SolidColorBrush x:Key="OverlayBrush"     Color="#3B3B3B"/>
        <SolidColorBrush x:Key="SidebarBrush"     Color="#212121"/>
        <SolidColorBrush x:Key="SidebarHover"     Color="#2C2C2C"/>
        <SolidColorBrush x:Key="SidebarActive"    Color="#333333"/>

        <SolidColorBrush x:Key="BorderBrush"      Color="#383838"/>
        <SolidColorBrush x:Key="BorderLightBrush"  Color="#494949"/>

        <SolidColorBrush x:Key="TextPrimary"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#999999"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#787878"/>
        <SolidColorBrush x:Key="TextAccent"       Color="#CCCCCC"/>

        <SolidColorBrush x:Key="AccentBrush"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="AccentHover"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SuccessBrush"     Color="#34D399"/>
        <SolidColorBrush x:Key="WarningBrush"     Color="#FBBF24"/>
        <SolidColorBrush x:Key="DangerBrush"      Color="#FB7185"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECONDARY BUTTON -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource OverlayBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnSecondary}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="#3D2020"/>
        </Style>

        <!-- SIDEBAR NAV BUTTON -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXTBOX -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DARK COMBOBOX TOGGLE BUTTON -->
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4"/>
                <Path x:Name="Arrow" Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- DARK COMBOBOX FULL TEMPLATE -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#333333"
                                            BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="4"
                                            Margin="0,2,0,0"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX ITEM -->
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource OverlayBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATAGRID SHARED STYLES -->
        <Style x:Key="DgColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#909090"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#383838"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#383838"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#323232"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================
             LEFT SIDEBAR
             ============================================================ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="18,18,18,20">
                    <TextBlock Text="AllO" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Sheet Manager" FontSize="11.5" FontWeight="Light"
                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Command="{Binding NavSheetListCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSheetListVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4C4;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sheet List" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavViewListCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsViewListVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F441;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="View List" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavRevisionsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRevisionsVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4DD;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Revisions" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="18,0,18,14">
                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding DocumentName}" FontSize="10.5"
                               Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding DocumentName}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================
             MAIN CONTENT AREA
             ============================================================ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== SHEET LIST PANEL ========== -->
            <Grid Grid.Row="0" Visibility="{Binding IsSheetListVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="+ New" Style="{StaticResource BtnPrimary}"
                                Command="{Binding ToggleCreatePanelCommand}" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Duplicate" Style="{StaticResource BtnSecondary}"
                                Command="{Binding DuplicateSelectedCommand}" Margin="0,0,6,0"/>
                        <Button Grid.Column="2" Content="Rename" Style="{StaticResource BtnSecondary}"
                                Command="{Binding ToggleFindReplaceCommand}" Margin="0,0,6,0"/>
                        <Button Grid.Column="3" Content="Delete" Style="{StaticResource BtnDanger}"
                                Command="{Binding DeleteSelectedCommand}" Margin="0,0,16,0"/>

                        <Rectangle Grid.Column="4" Width="1" Fill="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                        <Button Grid.Column="5" Content="Select All" Style="{StaticResource BtnSecondary}"
                                Command="{Binding SelectAllCommand}" Margin="0,0,4,0" FontSize="11" Padding="10,6"/>
                        <Button Grid.Column="6" Content="Select None" Style="{StaticResource BtnSecondary}"
                                Command="{Binding SelectNoneCommand}" FontSize="11" Padding="10,6"/>

                        <TextBox Grid.Column="8" Style="{StaticResource SearchBox}" Width="220"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>

                <!-- Sheet DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SheetsView}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2E2E2E"
                          Background="{StaticResource DeepBrush}" BorderThickness="0"
                          RowBackground="#252525" AlternatingRowBackground="#2C2C2C"
                          Foreground="{StaticResource TextPrimary}" FontSize="12.5"
                          RowHeight="38" ColumnHeaderHeight="36"
                          ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                          CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Number" Width="100" Binding="{Binding SheetNumber}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextAccent}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Sheet Name" Width="*" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding OriginalName}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding OriginalName}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WillChange}" Value="True">
                                                        <Setter Property="Text" Value="{Binding PreviewName}"/>
                                                        <Setter Property="Foreground" Value="#34D399"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Title Block ComboBox - binds by TypeId -->
                        <DataGridTemplateColumn Header="Title Block" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.TitleBlocks, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="TypeId"
                                              SelectedValue="{Binding TitleBlockTypeId, UpdateSourceTrigger=PropertyChanged}"
                                              ItemContainerStyle="{StaticResource DarkComboItem}"
                                              Style="{StaticResource DarkCombo}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Designed By" Width="100" Binding="{Binding DesignedBy}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Original" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding WillChange, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding OriginalName}"/>
                                                <Setter Property="Foreground" Value="#FB7185"/>
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                <Setter Property="FontSize" Value="11.5"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Find & Replace -->
                <Border Grid.Row="2" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="20,14"
                        Visibility="{Binding IsFindReplaceOpen, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="FIND" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding FindText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="REPLACE WITH" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="4" Content="Apply Rename" Style="{StaticResource BtnPrimary}"
                                Command="{Binding ApplyRenameCommand}" VerticalAlignment="Bottom"/>
                        <TextBlock Grid.Column="6" VerticalAlignment="Bottom" Margin="0,0,0,8">
                            <Run Text="{Binding AffectedCount, Mode=OneWay}" FontWeight="Bold"
                                 Foreground="{StaticResource TextAccent}"/>
                            <Run Text=" change(s)" Foreground="{StaticResource TextMuted}"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Create Sheet Panel -->
                <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="20,14"
                        Visibility="{Binding IsCreatePanelOpen, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="200"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TITLE BLOCK" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <ComboBox Style="{StaticResource DarkCombo}"
                                      ItemContainerStyle="{StaticResource DarkComboItem}"
                                      ItemsSource="{Binding TitleBlocks}"
                                      SelectedItem="{Binding SelectedTitleBlock}"
                                      DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="NUMBER" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding NewSheetNumber, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="SHEET NAME" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding NewSheetName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="6" Content="Create Sheet" Style="{StaticResource BtnPrimary}"
                                Command="{Binding CreateSheetCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========== VIEW LIST PANEL ========== -->
            <Grid Grid.Row="0" Visibility="{Binding IsViewListVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Delete" Style="{StaticResource BtnDanger}"
                                Command="{Binding DeleteViewsCommand}" Margin="0,0,16,0"/>

                        <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                        <Button Grid.Column="2" Content="Select All" Style="{StaticResource BtnSecondary}"
                                Command="{Binding ViewSelectAllCommand}" Margin="0,0,4,0" FontSize="11" Padding="10,6"/>
                        <Button Grid.Column="3" Content="Select None" Style="{StaticResource BtnSecondary}"
                                Command="{Binding ViewSelectNoneCommand}" FontSize="11" Padding="10,6"/>

                        <TextBox Grid.Column="5" Style="{StaticResource SearchBox}" Width="220"
                                 Text="{Binding ViewSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ViewsView}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2E2E2E"
                          Background="{StaticResource DeepBrush}" BorderThickness="0"
                          RowBackground="#252525" AlternatingRowBackground="#2C2C2C"
                          Foreground="{StaticResource TextPrimary}" FontSize="12.5"
                          RowHeight="38" ColumnHeaderHeight="36"
                          ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                          CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="View Name" Width="*" Binding="{Binding Name}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Type" Width="110" Binding="{Binding ViewType}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Scale" Width="80" Binding="{Binding Scale}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Template" Width="130" Binding="{Binding ViewTemplateName}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Discipline" Width="110" Binding="{Binding Discipline}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="On Sheet" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Text="{Binding SheetNumber}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOnSheet}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ========== REVISIONS PANEL ========== -->
            <Grid Grid.Row="0" Visibility="{Binding IsRevisionsVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="+ New Revision" Style="{StaticResource BtnPrimary}"
                                Command="{Binding ToggleCreateRevisionCommand}" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="Delete" Style="{StaticResource BtnDanger}"
                                Command="{Binding DeleteRevisionsCommand}" Margin="0,0,16,0"/>

                        <Rectangle Grid.Column="2" Width="1" Fill="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                        <Button Grid.Column="3" Content="Select All" Style="{StaticResource BtnSecondary}"
                                Command="{Binding RevSelectAllCommand}" Margin="0,0,4,0" FontSize="11" Padding="10,6"/>
                        <Button Grid.Column="4" Content="Select None" Style="{StaticResource BtnSecondary}"
                                Command="{Binding RevSelectNoneCommand}" FontSize="11" Padding="10,6"/>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Revisions}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Extended" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2E2E2E"
                          Background="{StaticResource DeepBrush}" BorderThickness="0"
                          RowBackground="#252525" AlternatingRowBackground="#2C2C2C"
                          Foreground="{StaticResource TextPrimary}" FontSize="12.5"
                          RowHeight="38" ColumnHeaderHeight="36"
                          ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                          CellStyle="{StaticResource DgCell}" RowStyle="{StaticResource DgRow}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="#" Width="45" Binding="{Binding Sequence}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextAccent}"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Date" Width="110" Binding="{Binding Date}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Issued By" Width="110" Binding="{Binding IssuedBy}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Issued To" Width="110" Binding="{Binding IssuedTo}" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Status with toggle button -->
                        <DataGridTemplateColumn Header="Status" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ToggleRevisionIssuedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" Cursor="Hand" Padding="0" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="StatusBd" CornerRadius="10" Padding="10,4" HorizontalAlignment="Center">
                                                    <TextBlock x:Name="StatusTxt" Text="{Binding Status}" FontSize="11" HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Issued">
                                                        <Setter TargetName="StatusBd" Property="Background" Value="#1A3A2A"/>
                                                        <Setter TargetName="StatusTxt" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        <Setter TargetName="StatusTxt" Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Not Issued">
                                                        <Setter TargetName="StatusBd" Property="Background" Value="#383838"/>
                                                        <Setter TargetName="StatusTxt" Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="StatusBd" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Create Revision Panel -->
                <Border Grid.Row="2" Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="20,14"
                        Visibility="{Binding IsCreateRevisionOpen, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DATE" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding NewRevDate, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="DESCRIPTION" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding NewRevDescription, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="ISSUED BY" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding NewRevIssuedBy, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="ISSUED TO" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="2,0,0,5"/>
                            <TextBox Style="{StaticResource SearchBox}"
                                     Text="{Binding NewRevIssuedTo, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Grid.Column="8" Content="Create" Style="{StaticResource BtnPrimary}"
                                Command="{Binding CreateRevisionCommand}" VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============================================================
                 STATUS BAR
                 ============================================================ -->
            <Border Grid.Row="1" Background="#1A1A1A"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="20,9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBlock Text=" items" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderBrush}" Margin="8,1"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedCount}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{StaticResource TextAccent}"/>
                        <TextBlock Text=" selected" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="3" Width="1" Fill="{StaticResource BorderBrush}" Margin="8,1"/>

                    <TextBlock Grid.Column="4" Text="{Binding StatusMessage}" FontSize="11.5"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>

                    <Button Grid.Column="6" Content="Refresh" Style="{StaticResource BtnSecondary}"
                            Command="{Binding RefreshCommand}" FontSize="11" Padding="12,5"/>
                    <Button Grid.Column="8" Content="Close" Style="{StaticResource BtnSecondary}"
                            Command="{Binding CloseCommand}" FontSize="11" Padding="12,5"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
