<Window x:Class="AllO.UI.Views.FamilyTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Copy families from link"
        Style="{StaticResource AllOWindow}"
        Height="460" Width="520"
        MinHeight="400" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Deep}">

    <Window.Resources>
        <Style x:Key="DkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel>
                <TextBlock Text="{Binding DocumentName}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <TextBlock Text="LINKED MODEL" Style="{StaticResource Lbl}"/>
                <ComboBox x:Name="LinksCombo" Style="{StaticResource DkCombo}"
                          ItemsSource="{Binding Links}"
                          SelectedItem="{Binding SelectedLink}"
                          DisplayMemberPath="Name"
                          ToolTip="Select a linked Revit model"
                          Margin="0,0,0,14"/>

                <TextBlock Text="CATEGORY (in link)" Style="{StaticResource Lbl}"/>
                <ComboBox Style="{StaticResource DkCombo}"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          IsEnabled="{Binding CategoriesEnabled}"
                          ToolTip="Select a category from the linked model"
                          Margin="0,0,0,14"/>

                <TextBlock Text="FAMILY TYPE" Style="{StaticResource Lbl}"/>
                <ComboBox Style="{StaticResource DkCombo}"
                          ItemsSource="{Binding FamilyTypes}"
                          SelectedItem="{Binding SelectedFamilyType}"
                          IsEnabled="{Binding FamilyTypesEnabled}"
                          ToolTip="Select the family type to copy into the host model"
                          Margin="0,0,0,14"/>

                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMuted}"
                           Text="Copies every instance of the selected type from the link into the host, using the link transform so positions match. In-place families are excluded from categories."/>
                <TextBlock Text="No linked models available" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,10,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ItemsSource.Count, ElementName=LinksCombo}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource Deep}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Content="Copy to host" Style="{StaticResource BtnPrimary}"
                        Command="{Binding CopyCommand}" IsEnabled="{Binding CanCopy}"
                        ToolTip="Copy all instances of the selected type into the current document"/>
                <Button Grid.Column="3" Content="Close" Style="{StaticResource BtnSecondary}" Command="{Binding CloseCommand}"
                        ToolTip="Close"/>
            </Grid>
        </Border>
    </Grid>
</Window>
