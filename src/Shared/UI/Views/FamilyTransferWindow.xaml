<Window x:Class="AllO.UI.Views.FamilyTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Copy families from link"
        Height="460" Width="520"
        MinHeight="400" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E">

    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#252525"/>
        <SolidColorBrush x:Key="Card" Color="#2C2C2C"/>
        <SolidColorBrush x:Key="Bdr" Color="#383838"/>
        <SolidColorBrush x:Key="Txt" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="Txt2" Color="#999999"/>
        <SolidColorBrush x:Key="TxtM" Color="#787878"/>
        <SolidColorBrush x:Key="Acc" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="AccH" Color="#FFFFFF"/>

        <Style x:Key="BtnP" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Acc}"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccH}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnS" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Card}"/>
            <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                                <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#686868"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Background" Value="#272727"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel>
                <TextBlock Text="AllO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Acc}"/>
                <TextBlock Text="Copy from linked model" FontSize="10" Foreground="{StaticResource TxtM}" Margin="1,0,0,0"/>
                <TextBlock Text="{Binding DocumentName}" FontSize="11" Foreground="{StaticResource Txt2}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <TextBlock Text="LINKED MODEL" Style="{StaticResource Lbl}"/>
                <ComboBox Style="{StaticResource DkCombo}"
                          ItemsSource="{Binding Links}"
                          SelectedItem="{Binding SelectedLink}"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,14"/>

                <TextBlock Text="CATEGORY (in link)" Style="{StaticResource Lbl}"/>
                <ComboBox Style="{StaticResource DkCombo}"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          IsEnabled="{Binding CategoriesEnabled}"
                          Margin="0,0,0,14"/>

                <TextBlock Text="FAMILY TYPE" Style="{StaticResource Lbl}"/>
                <ComboBox Style="{StaticResource DkCombo}"
                          ItemsSource="{Binding FamilyTypes}"
                          SelectedItem="{Binding SelectedFamilyType}"
                          IsEnabled="{Binding FamilyTypesEnabled}"
                          Margin="0,0,0,14"/>

                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TxtM}"
                           Text="Copies every instance of the selected type from the link into the host, using the link transform so positions match. In-place families are excluded from categories."/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TxtM}"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                <Button Grid.Column="1" Content="Copy to host" Style="{StaticResource BtnP}"
                        Command="{Binding CopyCommand}" IsEnabled="{Binding CanCopy}"/>
                <Button Grid.Column="3" Content="Close" Style="{StaticResource BtnS}" Command="{Binding CloseCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
