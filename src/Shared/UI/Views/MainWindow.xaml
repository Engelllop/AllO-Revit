<Window x:Class="AllO.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO - Batch Sheet Renamer"
        Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Deep}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBg}" Padding="20,15"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="AllO - Batch Sheet Renamer" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                <TextBlock Text="{Binding DocumentName}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="20,15"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Buscar" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource SearchBox}"
                             Text="{Binding FindText, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Reemplazar con" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource SearchBox}"
                             Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <Button Grid.Column="4" Content="Recargar" Style="{StaticResource BtnSecondary}" Click="Reload_Click" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" Margin="16,10" ItemsSource="{Binding Sheets}" AutoGenerateColumns="False"
                  IsReadOnly="True" Background="Transparent" Foreground="{StaticResource TextPrimary}"
                  BorderBrush="{StaticResource Border}" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource DataGridGridLine}"
                  RowBackground="{StaticResource DataGridRowEven}"
                  AlternatingRowBackground="{StaticResource DataGridRowOdd}"
                  ColumnHeaderStyle="{StaticResource DgColumnHeader}"
                  CellStyle="{StaticResource DgCell}"
                  RowStyle="{StaticResource DgRow}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N.°" Binding="{Binding SheetNumber}" Width="70"/>
                <DataGridTextColumn Header="Nombre Original" Binding="{Binding OriginalName}" Width="*"/>
                <DataGridTextColumn Header="Vista Previa" Binding="{Binding PreviewName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="{StaticResource Surface}" Padding="16,12"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextMuted}">
                    <Run Text="{Binding AffectedCount}" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                    <Run Text=" plano(s) por renombrar"/>
                </TextBlock>

                <Button Grid.Column="1" Content="Aplicar" Style="{StaticResource BtnPrimary}" Click="Apply_Click"/>
                <Button Grid.Column="3" Content="Cerrar" Style="{StaticResource BtnSecondary}" Click="Close_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource StatusBarBg}" Padding="14,8"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
        </Border>
    </Grid>
</Window>
