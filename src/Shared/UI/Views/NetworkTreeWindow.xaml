<Window x:Class="AllO.UI.Views.NetworkTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Network Tree"
        Style="{StaticResource AllOWindow}"
        Height="620" Width="640"
        MinHeight="420" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource Deep}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                Padding="22,14">
            <StackPanel>
                <TextBlock Text="{Binding RootTitle}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                <WrapPanel Margin="0,10,0,0">
                    <Border Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="TOTAL LENGTH" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding TotalLength}" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="LONGEST RUN" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding LongestPath}" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="ELBOWS" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Elbows}" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="FORKS (TEE/WYE)" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Forks}" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="TERMINALS" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Terminals}" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource Card}" BorderBrush="{StaticResource Border}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" Margin="0,0,8,4">
                        <StackPanel>
                            <TextBlock Text="RUNS" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Runs}" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
                <TextBlock Text="{Binding TruncatedNote}" FontSize="10" Foreground="{StaticResource Accent}"
                           Visibility="{Binding TruncatedVisibility}" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      Padding="22,14">
            <ItemsControl ItemsSource="{Binding Lines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12.5"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,1"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource StatusBarBg}" BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0" Padding="22,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Copy" Style="{StaticResource BtnSecondary}" FontSize="12" Padding="16,7"
                        Margin="0,0,8,0" Click="Copy_Click" ToolTip="Copy the tree and totals as text"/>
                <Button Content="Export CSV" Style="{StaticResource BtnSecondary}" FontSize="12" Padding="16,7"
                        Margin="0,0,8,0" Click="Export_Click" ToolTip="Export one row per run"/>
                <Button Content="Close" Style="{StaticResource BtnPrimary}" FontSize="12" Padding="16,7"
                        IsCancel="True" Click="Close_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
