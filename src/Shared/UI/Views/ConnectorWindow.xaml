<Window x:Class="AllO.UI.Views.ConnectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Connector"
        Height="620" Width="780"
        MinHeight="480" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Deep}">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg"   Color="#FAF9F5"/>
        <SolidColorBrush x:Key="Sf"   Color="#FAF9F6"/>
        <SolidColorBrush x:Key="Cd"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CdH"  Color="#F5F4EF"/>
        <SolidColorBrush x:Key="Bdr"  Color="#E8E6DC"/>
        <SolidColorBrush x:Key="Txt"  Color="#141413"/>
        <SolidColorBrush x:Key="Tx2"  Color="#5C5C5C"/>
        <SolidColorBrush x:Key="TxM"  Color="#B0AEA5"/>
        <SolidColorBrush x:Key="TxA"  Color="#6A9BCC"/>
        <SolidColorBrush x:Key="Acc"  Color="#D97757"/>
        <SolidColorBrush x:Key="AcH"  Color="#C45D3D"/>
        <SolidColorBrush x:Key="Wrn"  Color="#D4A017"/>
        <SolidColorBrush x:Key="Err"  Color="#C0392B"/>
        <SolidColorBrush x:Key="Suc"  Color="#788C5D"/>

        <Style x:Key="BtnP" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Acc}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource AcH}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnS" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Cd}"/>
            <Setter Property="Foreground" Value="{StaticResource Tx2}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource CdH}"/><Setter Property="Foreground" Value="{StaticResource Txt}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnWarn" TargetType="Button" BasedOn="{StaticResource BtnP}">
            <Setter Property="Background" Value="#B45309"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#92400E"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Txt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Acc}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox -->
        <ControlTemplate x:Key="CbTgl" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                <Border x:Name="Bg" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="{StaticResource Bdr}" BorderThickness="1" CornerRadius="4"/>
                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="#B1ADA1" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </ControlTemplate>

        <Style x:Key="DkCb" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource CbTgl}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" ClickMode="Press"/>
                            <TextBlock Text="{TemplateBinding SelectionBoxItem}" Margin="10,7,28,7" VerticalAlignment="Center" IsHitTestVisible="False" TextTrimming="CharacterEllipsis"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" Focusable="False" AllowsTransparency="True">
                                <Border Background="#FFFFFF" BorderBrush="{StaticResource Bdr}" BorderThickness="1" CornerRadius="4" Margin="0,2,0,0" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200"><StackPanel IsItemsHost="True"/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DkCbI" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#EBE9E3"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#F5E9E3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgHdr" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F6F1"/>
            <Setter Property="Foreground" Value="#8C8C8C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#DDDAD2"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DgC" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}"><ContentPresenter VerticalAlignment="Center"/></Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#F5E9E3"/><Setter Property="Foreground" Value="#2C2C2C"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgR" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EBE9E3"/></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource Sf}" BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="AllO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Acc}"/>
                    <TextBlock Text="Connector" FontSize="10" Foreground="{StaticResource TxM}" Margin="1,0,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="2" Style="{StaticResource TBox}" Width="200"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <!-- TOOLBAR -->
        <Border Grid.Row="1" Background="{StaticResource Sf}" BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Scan -->
                <Button Grid.Column="0" Style="{StaticResource BtnP}" Command="{Binding ScanCommand}" Padding="18,10"
                        ToolTip="Scan the model for disconnected elements">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Scan for Disconnected" FontSize="12"/>
                    </StackPanel>
                </Button>

                <!-- Category filter -->
                <TextBlock Grid.Column="2" Text="Filter:" FontSize="12" Foreground="{StaticResource Tx2}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="4" Style="{StaticResource DkCb}" Width="130"
                          ItemsSource="{Binding CategoryFilters}" SelectedItem="{Binding SelectedCategory}"
                          ItemContainerStyle="{StaticResource DkCbI}"
                          ToolTip="Filter elements by category"/>

                <!-- Tolerance -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Tolerance:" FontSize="12" Foreground="{StaticResource Tx2}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBox Style="{StaticResource TBox}" Width="60" Text="{Binding Tolerance, StringFormat=F1}" FontFamily="Consolas"
                             ToolTip="Maximum distance in feet to consider connectors as matching"/>
                    <TextBlock Text="ft" FontSize="11" Foreground="{StaticResource TxM}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Select All / None -->
                <Button Grid.Column="10" Content="Select All" Style="{StaticResource BtnS}" Command="{Binding SelectAllCommand}" FontSize="11" Padding="10,5" ToolTip="Select all elements in the list"/>
                <Button Grid.Column="12" Content="Select None" Style="{StaticResource BtnS}" Command="{Binding SelectNoneCommand}" FontSize="11" Padding="10,5" ToolTip="Deselect all elements in the list"/>
            </Grid>
        </Border>

        <!-- DISCONNECTED LIST -->
        <Grid Grid.Row="2">
            <DataGrid x:Name="DisconnectedGrid"
                      ItemsSource="{Binding DisconnectedView}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Extended" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Bdr}"
                  Background="{StaticResource Bg}" BorderThickness="0"
                  RowBackground="{StaticResource Sf}" AlternatingRowBackground="{StaticResource Cd}"
                  Foreground="{StaticResource Txt}" FontSize="12.5"
                  RowHeight="36" ColumnHeaderHeight="32"
                  ColumnHeaderStyle="{StaticResource DgHdr}" CellStyle="{StaticResource DgC}" RowStyle="{StaticResource DgR}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Element" Width="*" Binding="{Binding ElementName}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Foreground" Value="{StaticResource Txt}"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Category" Width="120" Binding="{Binding Category}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Foreground" Value="{StaticResource Tx2}"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="System" Width="160" Binding="{Binding SystemType}" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Foreground" Value="{StaticResource TxA}"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Open" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Err}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Center" Opacity="0.15">
                                <TextBlock Text="{Binding DisconnectedCount}" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource Wrn}" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Status" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Status}" FontSize="11" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TxM}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Connected">
                                                <Setter Property="Foreground" Value="{StaticResource Suc}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                <Setter Property="Foreground" Value="{StaticResource Err}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            </DataGrid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Items.Count, ElementName=DisconnectedGrid}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="&#xE836;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource TxM}" HorizontalAlignment="Center"/>
                <TextBlock Text="No disconnected elements found" Foreground="{StaticResource Tx2}" FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Click 'Scan for Disconnected' to analyze the model" Foreground="{StaticResource TxM}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="{StaticResource Bg}" BorderBrush="{StaticResource Bdr}" BorderThickness="0,1,0,0" Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding TotalCount}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Tx2}"/>
                    <TextBlock Text=" elements" FontSize="12" Foreground="{StaticResource TxM}"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource Bdr}" Margin="8,2"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{Binding TotalDisconnected}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource Wrn}"/>
                    <TextBlock Text=" open connectors" FontSize="12" Foreground="{StaticResource TxM}"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Fill="{StaticResource Bdr}" Margin="8,2"/>

                <TextBlock Grid.Column="4" Text="{Binding StatusMessage}" FontSize="11.5" Foreground="{StaticResource TxM}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="6" Style="{StaticResource BtnWarn}" Command="{Binding AutoConnectCommand}" Padding="16,8"
                        ToolTip="Automatically connect selected elements using nearest compatible connectors">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE836;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Auto Connect" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedCount, StringFormat=' ({0})'}" FontSize="12" Opacity="0.6"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="8" Content="Close" Style="{StaticResource BtnS}" Command="{Binding CloseCommand}" FontSize="11" Padding="12,5" ToolTip="Close"/>
            </Grid>
        </Border>
    </Grid>
</Window>
