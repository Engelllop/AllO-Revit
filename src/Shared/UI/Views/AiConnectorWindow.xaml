<Window x:Class="AllO.UI.Views.AiConnectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — A.I. Connector"
        Style="{StaticResource AllOWindow}"
        Height="430" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource Deep}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
            <TextBlock Text="A.I. Connector" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
            <Border x:Name="StatusBadge" Background="{StaticResource SuccessDim}" CornerRadius="5"
                    Padding="8,2" Margin="12,2,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="StatusBadgeText" Text="OFF" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource Success}"/>
            </Border>
        </StackPanel>
        <TextBlock Grid.Row="1" Text="Connects Claude (Code or Desktop) to this Revit session via a local MCP server. Claude can then read the model, inspect elements and write parameters."
                   FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <Border Grid.Row="2" Background="{StaticResource Card}" CornerRadius="8"
                BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="14,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="SERVER" Style="{StaticResource Lbl}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="EndpointBox" Style="{StaticResource SearchBox}" IsReadOnly="True"
                             Text="Stopped" VerticalAlignment="Center"/>
                    <Button x:Name="ToggleButton" Grid.Column="1" Content="Start" Style="{StaticResource BtnPrimary}"
                            FontSize="12" Padding="18,6" Margin="10,0,0,0" Click="Toggle_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource Card}" CornerRadius="8"
                BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="14,12">
            <StackPanel>
                <TextBlock Text="CONNECT CLAUDE" Style="{StaticResource Lbl}"/>
                <TextBlock Text="Claude Code (terminal) — run once:" FontSize="11"
                           Foreground="{StaticResource TextSecondary}" Margin="0,2,0,4"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ClaudeCmdBox" Style="{StaticResource SearchBox}" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="11"/>
                    <Button Grid.Column="1" Content="Copy" Style="{StaticResource BtnSecondary}"
                            FontSize="12" Padding="14,6" Margin="10,0,0,0" Click="Copy_Click"/>
                </Grid>
                <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap">
                    <Run Text="Claude Desktop: Settings → Connectors → Add custom connector → paste the server URL above."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                   VerticalAlignment="Bottom" Margin="0,12,0,12"
                   Text="The server only listens on this machine (localhost) and stops when Revit closes. You can close this window — the connection stays alive."/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Style="{StaticResource BtnPrimary}" FontSize="12" Padding="18,6"
                    IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
