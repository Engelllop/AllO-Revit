<Window x:Class="AllO.UI.Views.TableGenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AllO — Table Gen"
        Height="680" Width="920"
        MinHeight="550" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Deep}">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg"   Color="#FAF9F5"/>
        <SolidColorBrush x:Key="Sf"   Color="#FAF9F6"/>
        <SolidColorBrush x:Key="Cd"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CdH"  Color="#F5F4EF"/>
        <SolidColorBrush x:Key="Bdr"  Color="#E8E6DC"/>
        <SolidColorBrush x:Key="Txt"  Color="#141413"/>
        <SolidColorBrush x:Key="Tx2"  Color="#5C5C5C"/>
        <SolidColorBrush x:Key="TxM"  Color="#B0AEA5"/>
        <SolidColorBrush x:Key="TxA"  Color="#3D3D3D"/>
        <SolidColorBrush x:Key="Acc"  Color="#D97757"/>
        <SolidColorBrush x:Key="AcH"  Color="#C45D3D"/>
        <SolidColorBrush x:Key="Suc"  Color="#788C5D"/>
        <SolidColorBrush x:Key="Err"  Color="#C0392B"/>
        <SolidColorBrush x:Key="Teal" Color="#6A9BCC"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Tab Button -->
        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Tx2}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Padding="16,10" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Acc}"/>
                                <Setter Property="Foreground" Value="{StaticResource Txt}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Cd}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button -->
        <Style x:Key="BtnP" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Acc}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource AcH}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="BtnS" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Cd}"/>
            <Setter Property="Foreground" Value="{StaticResource Tx2}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource CdH}"/><Setter Property="Foreground" Value="{StaticResource Txt}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Teal accent button -->
        <Style x:Key="BtnTeal" TargetType="Button" BasedOn="{StaticResource BtnP}">
            <Setter Property="Background" Value="{StaticResource Teal}"/>
        </Style>

        <!-- Danger button -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnS}">
            <Setter Property="Foreground" Value="{StaticResource Err}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Err}"/>
        </Style>

        <!-- Dark ComboBox -->
        <ControlTemplate x:Key="CbTgl" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                <Border x:Name="Bg" Grid.ColumnSpan="2" Background="{StaticResource Sf}" BorderBrush="{StaticResource Bdr}" BorderThickness="1" CornerRadius="4"/>
                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="{StaticResource TxM}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="DkCb" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource CbTgl}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" ClickMode="Press"/>
                            <TextBlock Text="{TemplateBinding SelectionBoxItem}" Margin="10,7,28,7" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" Focusable="False" AllowsTransparency="True">
                                <Border Background="{StaticResource Cd}" BorderBrush="{StaticResource Bdr}" BorderThickness="1" CornerRadius="4" Margin="0,2,0,0" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="250"><StackPanel IsItemsHost="True"/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DkCbI" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/><Setter Property="FontSize" Value="12"/><Setter Property="Padding" Value="10,7"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBoxItem"><Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource CdH}"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource Acc}"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- ListBox -->
        <Style x:Key="DkLb" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource Sf}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bdr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style x:Key="DkLbI" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource CdH}"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource Acc}"/><Setter Property="Foreground" Value="{StaticResource Txt}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="{StaticResource Sf}" BorderBrush="{StaticResource Bdr}" BorderThickness="0,0,0,1" Padding="20,14,20,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="AllO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Acc}"/>
                    <TextBlock Text="Table Gen" FontSize="20" FontWeight="Light" Foreground="{StaticResource Txt}" Margin="10,0,0,0"/>
                    <TextBlock Text="Excel → drafting, legend, or key schedule" FontSize="11" Foreground="{StaticResource TxM}" VerticalAlignment="Bottom" Margin="12,0,0,4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Style="{StaticResource TabBtn}" GroupName="Tab" Content="Import New"
                                 IsChecked="{Binding ShowImport}" Command="{Binding ShowImportTabCommand}"/>
                    <RadioButton Style="{StaticResource TabBtn}" GroupName="Tab" Content="Manage Existing"
                                 IsChecked="{Binding ShowManage}" Command="{Binding ShowManageTabCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════ IMPORT TAB ═══════════════ -->
        <Grid Grid.Row="1" Grid.RowSpan="1" Visibility="{Binding ShowImport, Converter={StaticResource BoolToVis}}"
              Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: File list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="LOADED FILES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TxM}" Margin="0,0,0,8"/>

                <ListBox Grid.Row="1" x:Name="ImportTasksListBox" Style="{StaticResource DkLb}" ItemContainerStyle="{StaticResource DkLbI}"
                         ItemsSource="{Binding ImportTasks}" SelectedItem="{Binding SelectedTask}"
                         DisplayMemberPath="FileName"/>
                <Border Grid.Row="1" Background="{StaticResource Sf}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ImportTasksListBox, Path=Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource TxM}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No Excel files loaded" Foreground="{StaticResource Tx2}" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Click 'Add Excel' to import a spreadsheet" Foreground="{StaticResource TxM}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Style="{StaticResource BtnTeal}" Content="+ Add Excel" Padding="14,8" FontSize="12"
                            Command="{Binding AddFilesCommand}" Margin="0,0,8,0"
                            ToolTip="Add Excel files to import"/>
                    <Button Style="{StaticResource BtnS}" Content="- Remove" Padding="14,8" FontSize="12"
                            Command="{Binding RemoveFileCommand}"
                            ToolTip="Remove selected file from the list"/>
                </StackPanel>
            </Grid>

            <!-- RIGHT: Config panel (visible when a file is selected) -->
            <Grid Grid.Column="2" Visibility="{Binding ShowConfig, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="IMPORT SETTINGS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TxM}" Margin="0,0,0,12"/>

                <!-- Worksheet -->
                <TextBlock Grid.Row="1" Text="Worksheet:" FontSize="12" Foreground="{StaticResource Tx2}" Margin="0,0,0,4"/>
                <ComboBox Grid.Row="2" Style="{StaticResource DkCb}" ItemContainerStyle="{StaticResource DkCbI}"
                          ItemsSource="{Binding AvailableSheets}"
                          SelectedItem="{Binding SelectedTask.SelectedSheet, Mode=TwoWay}"
                          SelectionChanged="OnSheetSelectionChanged"
                          Margin="0,0,0,14"
                          ToolTip="Select the Excel worksheet to import"/>

                <!-- Range -->
                <TextBlock Grid.Row="3" Text="Range:" FontSize="12" Foreground="{StaticResource Tx2}" Margin="0,0,0,4"/>
                <ComboBox Grid.Row="4" Style="{StaticResource DkCb}" ItemContainerStyle="{StaticResource DkCbI}"
                          ItemsSource="{Binding AvailableRanges}"
                          SelectedItem="{Binding SelectedTask.SelectedRange, Mode=TwoWay}"
                          Margin="0,0,0,14"
                          ToolTip="Select the cell range to import"/>

                <!-- View Type -->
                <TextBlock Grid.Row="5" Text="View Type:" FontSize="12" Foreground="{StaticResource Tx2}" Margin="0,0,0,4"/>
                <ComboBox Grid.Row="6" Style="{StaticResource DkCb}" ItemContainerStyle="{StaticResource DkCbI}"
                          ItemsSource="{Binding ViewTypeOptions}"
                          SelectedItem="{Binding SelectedTask.SelectedViewType, Mode=TwoWay}"
                          Margin="0,0,0,20"
                          ToolTip="Choose the Revit view type for the imported table"/>

                <!-- Status -->
                <Border Grid.Row="7" Background="{StaticResource Cd}" CornerRadius="8" Padding="14,12" VerticalAlignment="Top"
                        BorderBrush="{StaticResource Bdr}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="File Info" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Tx2}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding SelectedTask.FileName}" FontSize="12" Foreground="{StaticResource Txt}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TxM}" Margin="0,4,0,0">
                            <Run Text="Status: "/><Run Text="{Binding SelectedTask.Status}" Foreground="{StaticResource Suc}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════════════ MANAGE TAB ═══════════════ -->
        <Grid Grid.Row="1" Visibility="{Binding ShowManage, Converter={StaticResource BoolToVis}}" Margin="20,16,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="IMPORTED TABLE VIEWS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TxM}" Margin="0,0,0,8"/>

            <!-- Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Style="{StaticResource BtnS}" Content="Select All" FontSize="11" Padding="10,5" Margin="0,0,6,0"
                        Command="{Binding SelectAllCommand}"
                        ToolTip="Select all imported table views"/>
                <Button Style="{StaticResource BtnS}" Content="Select None" FontSize="11" Padding="10,5"
                        Command="{Binding SelectNoneCommand}"
                        ToolTip="Deselect all imported table views"/>
            </StackPanel>

            <!-- List of existing views -->
            <ListBox Grid.Row="2" x:Name="ExistingViewsListBox" Style="{StaticResource DkLb}" ItemsSource="{Binding ExistingViews}" SelectionMode="Extended">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Txt}"/>
                                    <TextBlock Text="{Binding ViewKind}" FontSize="10" Foreground="{StaticResource Teal}" Margin="8,2,0,0"/>
                                </StackPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource TxM}">
                                    <Run Text="{Binding ExcelPath, Mode=OneWay}"/>
                                    <Run Text=" ["/><Run Text="{Binding SheetName, Mode=OneWay}"/><Run Text="]"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Row="2" Background="{StaticResource Sf}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=ExistingViewsListBox, Path=Items.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource TxM}" HorizontalAlignment="Center"/>
                    <TextBlock Text="No imported table views" Foreground="{StaticResource Tx2}" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Style="{StaticResource BtnS}" Content="Reload from Excel" Padding="14,8" FontSize="12"
                        Command="{Binding ReloadCommand}" Margin="0,0,8,0"
                        ToolTip="Reload table data from the original Excel file"/>
                <Button Style="{StaticResource BtnDanger}" Content="Delete Views" Padding="14,8" FontSize="12"
                        Command="{Binding DeleteCommand}"
                        ToolTip="Delete selected imported table views"/>
            </StackPanel>
        </Grid>

        <!-- ═══ PROGRESS BAR ═══ -->
        <Border Grid.Row="2" Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}"
                Margin="20,8,20,0">
            <ProgressBar Height="6" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                         Background="{StaticResource Sf}" BorderThickness="0">
                <ProgressBar.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E0E0E0" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </ProgressBar.Foreground>
            </ProgressBar>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="{StaticResource Bg}" BorderBrush="{StaticResource Bdr}" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="11.5" Foreground="{StaticResource TxM}" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Style="{StaticResource BtnP}" Content="Import All"
                        Command="{Binding ImportCommand}" Visibility="{Binding ShowImport, Converter={StaticResource BoolToVis}}"
                        Padding="18,8" FontSize="12"
                        ToolTip="Import all loaded Excel files into Revit"/>

                <Button Grid.Column="3" Style="{StaticResource BtnS}" Content="Close"
                        Command="{Binding CloseCommand}" FontSize="11" Padding="12,5"
                        ToolTip="Close the Table Gen window"/>
            </Grid>
        </Border>
    </Grid>
</Window>
